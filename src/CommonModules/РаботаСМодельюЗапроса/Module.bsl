#Область ПрограммныйИнтерфейс

#Область Конструктор

// Новый модель запроса
// 
// Возвращаемое значение:
//  Структура - Новый модель запроса:
// * СхемаЗапроса - СхемаЗапроса
// * Стек - Массив из Структура
// 
// * ЗапросПакета - ЗапросВыбораСхемыЗапроса, ЗапросУничтоженияТаблицыСхемыЗапроса -
// * ВложенныйЗапрос - ЗапросВыбораСхемыЗапроса -
// * ОператорВыбрать - ОператорВыбратьСхемыЗапроса -
// * Источник - ИсточникСхемыЗапроса -
// * Соединение - СоединениеИсточникаЗапросаСхемыЗапроса -
// * ТипСоединения - ТипСоединенияСхемыЗапроса -
// * ИсточникСлева - ИсточникСхемыЗапроса -
// * ИсточникСправа - ИсточникСхемыЗапроса -
// 
// * Поле - ВыражениеСхемыЗапроса -
// * КонтрольнаяТочка - КонтрольнаяТочкаИтоговСхемыЗапроса -
// 
// * МенеджерВременныхТаблиц - МенеджерВременныхТаблиц -
// * Параметры - Структура
// 
// * СтруктураЗапроса - Структура
// * Запрос - Запрос
// * Результат - РезультатЗапроса
// * Выбран - Булево
Функция НовыйМодельЗапроса() Экспорт
	
	МодельЗапроса = Новый Структура;
	МодельЗапроса.Вставить("СхемаЗапроса", Новый СхемаЗапроса);
	МодельЗапроса.Вставить("Стек", Новый Массив);
	// Запрос
	МодельЗапроса.Вставить("ЗапросПакета");
	МодельЗапроса.Вставить("ВложенныйЗапрос");
	МодельЗапроса.Вставить("ОператорВыбрать");
	МодельЗапроса.Вставить("ИндексЗапроса", Новый Структура);

	МодельЗапроса.Вставить("ИндексОператора");
	МодельЗапроса.Вставить("ВыбираемыеПоля");
	МодельЗапроса.Вставить("Колонки");
	// Источник
	МодельЗапроса.Вставить("Источник");
	МодельЗапроса.Вставить("ДоступныеПоля");
	// Соединение
	МодельЗапроса.Вставить("ИсточникСлева");
	МодельЗапроса.Вставить("ИсточникСправа");
	МодельЗапроса.Вставить("Соединение");
	МодельЗапроса.Вставить("ТипСоединения");
	// Поле
	МодельЗапроса.Вставить("Поле");
	МодельЗапроса.Вставить("КонтрольнаяТочка");
	// Параметры и менеджер ВТ
	МодельЗапроса.Вставить("МенеджерВременныхТаблиц");
	МодельЗапроса.Вставить("Параметры", Новый Структура);
	// Результат
	МодельЗапроса.Вставить("Запрос");
	МодельЗапроса.Вставить("Результат");
	МодельЗапроса.Вставить("ИндексРезультата", Новый Структура);
	МодельЗапроса.Вставить("Выбран", Ложь);
	//@skip-check constructor-function-return-section
	Возврат МодельЗапроса;

КонецФункции

Функция МодельЗапроса(Параметр1 = Неопределено, Параметр2 = Неопределено) Экспорт
	
	МодельЗапроса = Обработки.МодельЗапроса.Создать();
	
	// Проверка 1-го параметра. Параметр может быть сложного типа, поэтому явная проверка на значение
	Если Параметр1 = Неопределено ИЛИ ПустаяСтрока(Параметр1) Тогда
		Возврат МодельЗапроса;
	КонецЕсли;
	
	ТипПараметра1 = ТипЗнч(Параметр1);
	
	Если ТипПараметра1 = Тип("СхемаКомпоновкиДанных") Тогда
		МодельЗапроса.УстановитьСхемуКомпоновкиДанных(Параметр1, Параметр2);
		Возврат МодельЗапроса;
	КонецЕсли;
	
	Если ТипПараметра1 = Тип("ТаблицаФормы") Тогда
		МодельЗапроса.УстановитьСхемуТаблицыСписка(Параметр1);
		Возврат МодельЗапроса;
	КонецЕсли;
	
	Если ТипПараметра1 = Тип("ДинамическийСписок") Тогда
		МодельЗапроса.УстановитьСхемуДинамическогоСписка(Параметр1);
		Возврат МодельЗапроса;
	КонецЕсли;
	
	Если ТипПараметра1 = Тип("Запрос") Тогда
		МодельЗапроса.УстановитьЗапрос(Параметр1);
		Возврат МодельЗапроса;
	КонецЕсли;
	
	Если ТипПараметра1 = Тип("СхемаЗапроса") Тогда
		Если ТипЗнч(Параметр2) = Тип("МенеджерВременныхТаблиц") Тогда
			МодельЗапроса.УстановитьМенеджерВременныхТаблиц(Параметр2);
		КонецЕсли;
		МодельЗапроса.УстановитьСхемуЗапроса(Параметр1);
		Возврат МодельЗапроса;
	КонецЕсли;
	
	Если ТипПараметра1 = Тип("МенеджерВременныхТаблиц") Тогда
		МодельЗапроса.УстановитьМенеджерВременныхТаблиц(Параметр1);
		Возврат МодельЗапроса;
	КонецЕсли;
	
	МодельЗапроса.УстановитьТекстЗапроса(Параметр1);
	Возврат МодельЗапроса;
	
КонецФункции

// Установить запрос.
// 
// Параметры:
//  НовыйЗапрос - Запрос
// 
// Возвращаемое значение:
//  ОбработкаОбъект.МодельЗапроса
Процедура УстановитьЗапрос(МодельЗапроса, НовыйЗапрос) Экспорт
	УстановитьМенеджерВременныхТаблиц(МодельЗапроса, НовыйЗапрос.МенеджерВременныхТаблиц);
	УстановитьТекстЗапроса(МодельЗапроса, НовыйЗапрос.Текст);
	Для Каждого ПараметрЗапроса Из НовыйЗапрос.Параметры Цикл
		Параметр(МодельЗапроса, ПараметрЗапроса.Ключ, ПараметрЗапроса.Значение);
	КонецЦикла;
КонецПроцедуры

Процедура УстановитьСхемуЗапроса(МодельЗапроса, НоваяСхемаЗапроса) Экспорт
	МодельЗапроса.СхемаЗапроса = НоваяСхемаЗапроса;
	УстановитьЗапросПакета(МодельЗапроса);
КонецПроцедуры

Процедура УстановитьМенеджерВременныхТаблиц(МодельЗапроса, НовыйМенеджерВременныхТаблиц) Экспорт
	МодельЗапроса.МенеджерВременныхТаблиц = НовыйМенеджерВременныхТаблиц;
КонецПроцедуры

Процедура УстановитьТекстЗапроса(МодельЗапроса, ТекстЗапроса) Экспорт
	МодельЗапроса.СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	УстановитьЗапросПакета(МодельЗапроса);
КонецПроцедуры

#Область СКД

Процедура УстановитьСхемуКомпоновкиДанных(МодельЗапроса, Схема, Настройки) Экспорт
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновкиДанных = КомпоновщикМакета.Выполнить(Схема, Настройки);
	ТекстЗапроса = МакетКомпоновкиДанных.НаборыДанных[0].Запрос;
	УстановитьТекстЗапроса(МодельЗапроса, ТекстЗапроса);
	Для Каждого ЗначениеПараметра Из МакетКомпоновкиДанных.ЗначенияПараметров Цикл
		Параметр(МодельЗапроса, ЗначениеПараметра.Имя, ЗначениеПараметра.Значение);
	КонецЦикла;
КонецПроцедуры

Процедура УстановитьСхемуТаблицыСписка(МодельЗапроса, ТаблицаСписка) Экспорт
	Схема = ТаблицаСписка.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
	Настройки = ТаблицаСписка.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
	// Добавить в настройку отбор по текущей строке
	ПоляКлюча = ТаблицаСписка.ТекущаяСтрока;
	Если ПоляКлюча <> Неопределено Тогда
		Для Каждого ПолеКлюча Из ПоляКлюча Цикл
			ДобавитьОтборСКД(Настройки.Отбор, ПолеКлюча.Ключ, ПолеКлюча.Значение, ВидСравненияКомпоновкиДанных.Равно, Истина);
		КонецЦикла;
	КонецЕсли;
	// Добавить в настройку доступные поля
	Настройки.Структура[0].Выбор.Элементы.Очистить();
	Для Каждого ДоступноеПоле Из Настройки.Структура[0].Выбор.ДоступныеПоляВыбора.Элементы Цикл
		Если ДоступноеПоле.Таблица ИЛИ ДоступноеПоле.Папка Тогда
			Продолжить;
		КонецЕсли;
		ДобавитьВыбранноеПолеСКД(Настройки.Структура[0].Выбор, ДоступноеПоле.Поле);
	КонецЦикла;
	// Инициировать схему с настройками
	УстановитьСхемуКомпоновкиДанных(МодельЗапроса, Схема, Настройки);
КонецПроцедуры

Процедура УстановитьСхемуДинамическогоСписка(МодельЗапроса, Список) Экспорт
	УстановитьТекстЗапроса(МодельЗапроса, Список.ТекстЗапроса);
	Для Каждого ЭлементПараметра Из Список.Параметры.Элементы Цикл
		Параметр(МодельЗапроса, Строка(ЭлементПараметра.Параметр), ЭлементПараметра.Значение);
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область Курсор

Процедура УстановитьИсточник(МодельЗапроса, ИндексИлиПсевдоним = Неопределено) Экспорт
	МодельЗапроса.Источник = ПолучитьИсточник(МодельЗапроса, ИндексИлиПсевдоним);
КонецПроцедуры

Процедура УстановитьОператор(МодельЗапроса, Индекс = Неопределено) Экспорт
	ЗапросПакета = МодельЗапроса.ЗапросПакета;
	Если ТипЗнч(ЗапросПакета) = Тип("ЗапросУничтоженияТаблицыСхемыЗапроса") Тогда
		Возврат;
	КонецЕсли;
	Если Индекс = Неопределено Тогда
		ВыбранныйИндекс = ЗапросПакета.Операторы.Количество() - 1;
	Иначе
		ВыбранныйИндекс = Индекс;
	КонецЕсли;
	ОператорВыбрать = ЗапросПакета.Операторы[ВыбранныйИндекс];
	УстановитьИсточник(МодельЗапроса);
КонецПроцедуры

Функция УстановитьЗапросПакета(МодельЗапроса, Индекс = Неопределено) Экспорт
	Перем ВыбранныйИндекс;
	СхемаЗапроса = МодельЗапроса.СхемаЗапроса;
	Если Индекс = Неопределено Тогда
		ВыбранныйИндекс = СхемаЗапроса.ПакетЗапросов.Количество() - 1;
	ИначеЕсли ТипЗнч(Индекс) = Тип("Строка") Тогда
		Для Каждого Элемент Из СхемаЗапроса.ПакетЗапросов Цикл
			Если Элемент.ТаблицаДляПомещения = Индекс Тогда
				ВыбранныйИндекс = СхемаЗапроса.ПакетЗапросов.Индекс(Элемент);
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если ВыбранныйИндекс = Неопределено Тогда
			ВызватьИсключение "Не найден запрос с именем """ + Индекс + """";
		КонецЕсли;
	Иначе
		ВыбранныйИндекс = Индекс;
	КонецЕсли;
	ЗапросПакета = СхемаЗапроса.ПакетЗапросов[ВыбранныйИндекс];
	УстановитьОператор(МодельЗапроса);
КонецФункции

#КонецОбласти

#Область ЗапросПакета

Процедура Поместить(МодельЗапроса, ИмяВременнойТаблицы) Экспорт
	МодельЗапроса.ЗапросПакета.ТаблицаДляПомещения = ИмяВременнойТаблицы;
КонецПроцедуры


// Описание запроса.
// 
// Параметры:
//  МодельЗапроса - см. НовыйМодельЗапроса
//  ИмяЗапроса - Строка - Имя запроса
Процедура УстановитьИмяЗапроса(МодельЗапроса, ИмяЗапроса) Экспорт

	Индекс = МодельЗапроса.СхемаЗапроса.ПакетЗапросов.Количество()-1;
	МодельЗапроса.ИндексЗапроса.Вставить(ИмяЗапроса, Индекс);
	
КонецПроцедуры

// Добавляет оператор создания нового запроса в пакете
// 
// Параметры:
//  МодельЗапроса - см. НовыйМодельЗапроса
//  ИмяЗапроса - Строка - Имя запроса, которое может быть использовано при именованном обращении к результату запроса
Процедура ЗапросПакета(МодельЗапроса, ИмяЗапроса = "") Экспорт
	
	ЗаполнитьЗначенияСвойств(МодельЗапроса, НовыйСостояние());
	ПакетЗапросов = МодельЗапроса.СхемаЗапроса.ПакетЗапросов;
	
	Если ПакетЗапросов.Количество() = 1 И МодельЗапроса.СхемаЗапроса.ПолучитьТекстЗапроса() = "" Тогда
		
		ЗапросПакета = ПакетЗапросов[0];//  дефолтный запрос
		
	Иначе
		
		ЗапросПакета = ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
		
	КонецЕсли;
	
	МодельЗапроса.ЗапросПакета = ЗапросПакета;

	Если НЕ ПустаяСтрока(ИмяЗапроса) Тогда
		УстановитьИмяЗапроса(МодельЗапроса, ИмяЗапроса);
	КонецЕсли;

	МодельЗапроса.Колонки = ЗапросПакета.Колонки;
		
КонецПроцедуры

Процедура Индекс(МодельЗапроса, Поля, Уникальный = Ложь) Экспорт
	ИндексТаблицыЗапроса = МодельЗапроса.ЗапросПакета.Индексы.Добавить();//ИндексыСхемыЗапроса
	ИндексТаблицыЗапроса.Уникальный = Уникальный;
	ВыраженияИндекса = ИндексТаблицыЗапроса.ВыраженияИндекса;// ВыраженияИндексаСхемыЗапроса
	Для Каждого Поле Из ОбщийКлиентСервер.Массив(Поля) Цикл
		ВыраженияИндекса.Добавить(Поле);
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область Источник

Процедура Источник(МодельЗапроса, Таблица, Знач Псевдоним = "", ПараметрыТаблицы = Неопределено) Экспорт
	
	Если МодельЗапроса.ОператорВыбрать = Неопределено Тогда
		Выбрать(МодельЗапроса);
	КонецЕсли;
	
	ТипИсточника = ТипЗнч(Таблица);
	
	Если ТипИсточника = Тип("Строка") Тогда

		Если СтрНачинаетсяС(Таблица, "{") Тогда
			//  Это таблица JSON
			ТаблицаИзJSON = РаботаСКоллекцией.СтруктураВТаблицуЗначений(Таблица);
			Источник(МодельЗапроса, ТаблицаИзJSON, Псевдоним);
			Возврат;
			
		КонецЕсли;
		
		Если СтрНачинаетсяС(Таблица, "&") Тогда
			//  Это параметр
			ДобавитьОписаниеВременнойТаблицы(МодельЗапроса, Таблица, Псевдоним);
			
			Если ПараметрыТаблицы <> Неопределено Тогда
				ИмяПараметра = Прав(Таблица, СтрДлина(Таблица) - 1);
				Параметр(МодельЗапроса, ИмяПараметра, ПараметрыТаблицы);
			КонецЕсли;
			
			Возврат;
			
		КонецЕсли;

		МенеджерВременныхТаблиц = МодельЗапроса.МенеджерВременныхТаблиц;
		ВременнаяТаблица = ?(МенеджерВременныхТаблиц <> Неопределено, МенеджерВременныхТаблиц.Таблицы.Найти(Таблица), Неопределено);
		
		Если ВременнаяТаблица <> Неопределено Тогда
			//  Это имя временной таблицы из менеджера временных таблиц
			ДобавитьОписаниеВременнойТаблицы(МодельЗапроса, Таблица, Псевдоним);
			
			Для Каждого Колонка Из ВременнаяТаблица.Колонки Цикл
				// При добавлении доступного поля необходимо указать Тип, хотя фактическое значение будет иметь тип ТипЗначения.
				// Ограничения:
				// 1. Доступ к полям через точку (например, Поле.ПодПоле) поддерживается только для объектов одного типа.
				// 2. Запрещено использовать оператор ССЫЛКА.
				// Обходное решение:
				// 1. Для работы с данными разных типов используйте явные соединения таблиц вместо вложенных полей.
				// 2. Для определения типа значения используйте функцию ТипЗначения() вместо ССЫЛКА.
				ДоступноеПоле(МодельЗапроса, Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
			КонецЦикла;
			
			Возврат;
			
		КонецЕсли;
		
		//  Это имя доступной таблицы в текущей схеме запроса
		ДобавитьИсточник(МодельЗапроса, Таблица, ?(ПустаяСтрока(Псевдоним), ОбщийКлиентСервер.ОкончаниеСтрокиПослеРазделителя(Таблица), Псевдоним));
		
		Если ПараметрыТаблицы <> Неопределено Тогда
			УстановитьПараметрыВиртуальнойТаблицы(МодельЗапроса.Источник, ПараметрыТаблицы);
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
	
	//  Это Таблица значений, ТабличнаяЧасть, ДанныеФормыКоллекцияЗначений
	ИмяПараметра = ОбщийКлиентСервер.ИмяПоУникальномуИдентификатору();
	ДобавитьОписаниеВременнойТаблицы(МодельЗапроса, "&" + ИмяПараметра, Псевдоним);
	
	Если ТипИсточника = Тип("ТаблицаЗначений") Тогда
		Для Каждого Колонка Из Таблица.Колонки Цикл
			ДоступноеПоле(МодельЗапроса, Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(МодельЗапроса, ИмяПараметра, Таблица);
	ИначеЕсли ТипИсточника = Тип("ДанныеФормыКоллекция") Тогда
		Результат = Таблица.Выгрузить();
		Для Каждого Колонка Из Результат.Колонки Цикл
			Если Колонка.Имя = "ИсходныйНомерСтроки" Тогда
				Продолжить;
			КонецЕсли;
			ДоступноеПоле(МодельЗапроса, Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(МодельЗапроса, ИмяПараметра, Результат);
	ИначеЕсли СтрНайти(Таблица, "ТабличнаяЧасть.") > 0 Тогда
		Результат = Таблица.Выгрузить();
		Для Каждого Колонка Из Результат.Колонки Цикл
			ДоступноеПоле(МодельЗапроса, Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(МодельЗапроса, ИмяПараметра, Результат);
	ИначеЕсли ТипИсточника = Тип("Структура") Тогда
		ТаблицаИзJSON = РаботаСКоллекцией.СтруктураВТаблицуЗначений(Таблица);
		Для Каждого Колонка Из ТаблицаИзJSON.Колонки Цикл
			ДоступноеПоле(МодельЗапроса, Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(МодельЗапроса, ИмяПараметра, ТаблицаИзJSON);
	ИначеЕсли ТипИсточника = Тип("ТабличныйДокумент") Тогда
		ОбластьЯчеек = Таблица.Область(1, 1, Таблица.ВысотаТаблицы, Таблица.ШиринаТаблицы);
		Построитель = Новый ПостроительЗапроса;
		Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(ОбластьЯчеек);
		Построитель.ДобавлениеПредставлений = ТипДобавленияПредставлений.НеДобавлять;
		Построитель.ЗаполнитьНастройки();
		Построитель.Выполнить();
		Результат = Построитель.Результат.Выгрузить();
		Для Каждого Колонка Из Результат.Колонки Цикл
			ДоступноеПоле(МодельЗапроса, Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(МодельЗапроса, ИмяПараметра, Результат);
	Иначе
		ВызватьИсключение СтрШаблон("Неизвестный тип источника %1", ТипИсточника);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЛевоеСоединение(МодельЗапроса, ПсевдонимСлева, ПсевдонимСправа, Условие = Неопределено) Экспорт
