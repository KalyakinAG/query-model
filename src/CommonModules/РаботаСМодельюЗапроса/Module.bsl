// Добавить условие соединения
// 
// Параметры:
//  СоответствиеПолей - Строка - условие соединения описывается через перечисление соответствия полей: ПолеСлева = ПолеСправа[,..]
//                               Допускается указать справа параметр: ПолеСлева = &Параметр. Если поля имеют одинаковое имя слева и справа, то
//                               достаточно указать просто имя поля: Поле, ПолеСлева = ПолеСправа[,..]
// 
Процедура Связь(МодельЗапроса, СоответствиеПолей, Действует = Истина) Экспорт
	Перем ДоступныеПоля;
	
	Если СоответствиеПолей = "*" Тогда
		ОбщиеПоля = Новый Массив;
		ДоступныеПоля = МодельЗапроса.ИсточникСправа.Источник.ДоступныеПоля;
		Для Каждого ПолеСлева Из МодельЗапроса.ИсточникСлева.Источник.ДоступныеПоля Цикл
			Если ДоступныеПоля.Найти(ПолеСлева.Имя) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ОбщиеПоля.Добавить(ПолеСлева.Имя);
		КонецЦикла;
		Выражение = УсловиеСоединения(ОбщиеПоля);
	Иначе
		Выражение = УсловиеСоединения(СоответствиеПолей);
	КонецЕсли;
	
	УсловиеСвязи(МодельЗапроса, Выражение, Действует);
	
КонецПроцедуры

// Добавить условие соединения
// 
// Параметры:
//  Выражение - Строка - Выражение условия соединения
Процедура УсловиеСвязи(МодельЗапроса, Знач Выражение, Действует = Истина) Экспорт

	Если НЕ Действует Тогда
		Возврат;
	КонецЕсли;
	
	ИсточникСлева = МодельЗапроса.ИсточникСлева;
	ПсевдонимСлева = ИсточникСлева.Источник.Псевдоним;
	ИсточникСправа = МодельЗапроса.ИсточникСправа;
	ПсевдонимСправа = ИсточникСправа.Источник.Псевдоним;
	Выражение = СтрЗаменить(Выражение, "%1", ПсевдонимСлева); 
	Выражение = СтрЗаменить(Выражение, "%2", ПсевдонимСправа);

	Если МодельЗапроса.Соединение = Неопределено Тогда
		
		ИсточникСлева.Соединения.Добавить(ПсевдонимСправа, Выражение);
		Соединение = ИсточникСлева.Соединения[МодельЗапроса.ИсточникСлева.Соединения.Количество()-1];
		Соединение.ТипСоединения = МодельЗапроса.ТипСоединения;
		МодельЗапроса.Соединение = Соединение;
		Возврат; 

	КонецЕсли;
	
	ДобавитьУсловиеСоединения(МодельЗапроса.Соединение, Выражение);		

КонецПроцедуры

Процедура ИсточникНачать(МодельЗапроса, Псевдоним) Экспорт
	ДобавитьВложенныйЗапрос(МодельЗапроса, Псевдоним);
	ВложенныйЗапрос = МодельЗапроса.Источник.Источник.Запрос;
	СохранитьСостояние(МодельЗапроса);
	МодельЗапроса.ЗапросПакета = ВложенныйЗапрос; 
	МодельЗапроса.Колонки = ВложенныйЗапрос.Колонки;
КонецПроцедуры

Процедура ИсточникЗавершить(МодельЗапроса) Экспорт
	ВосстановитьСостояние(МодельЗапроса);
КонецПроцедуры

Процедура ЗаменитьИсточник(МодельЗапроса, ПсевдонимИсточника, Таблица, НовыйПсевдоним = "") Экспорт
	
	Если ПустаяСтрока(НовыйПсевдоним) Тогда
		Псевдоним = ПсевдонимИсточника;
	КонецЕсли;
	
	ЗапросПакета = МодельЗапроса.ЗапросПакета;
	ОператорВыбрать = МодельЗапроса.ОператорВыбрать;
	ИндексОператора = ЗапросПакета.Операторы.Индекс(ОператорВыбрать);
	Источник = ОператорВыбрать.Источники.НайтиПоПсевдониму(ПсевдонимИсточника);
	ИндексИсточника = ОператорВыбрать.Источники.Индекс(Источник);
	
	// Сохранить все поля запроса
	ВыбираемыеПоля  = Новый Массив;
	Для Каждого Колонка Из ЗапросПакета.Колонки Цикл
		Выражение =  Строка(Колонка.Поля[ИндексОператора]);
		Если ПустаяСтрока(Выражение) Тогда // при нескольких объединениях часть полей может отсутствовать (NULL поля)
			Продолжить;
		КонецЕсли;
		ВыбираемыеПоля.Добавить(Новый Структура("Выражение, Псевдоним", Строка(Колонка.Поля[ИндексОператора]), Колонка.Псевдоним));
	КонецЦикла;
	
	// Сохранить все отборы
	Отборы = Новый Массив;
	Для Каждого Отбор Из ОператорВыбрать.Отбор Цикл
		Отборы.Добавить(Строка(Отбор));
	КонецЦикла;
	
	// Сохранить все соединения с источником
	Соединения = Новый Массив;
	Для Каждого ЭлементИсточника Из ОператорВыбрать.Источники Цикл
		Для Каждого ЭлементСоединения Из ЭлементИсточника.Соединения Цикл
			Если СтрНайти(ЭлементСоединения.Условие, ПсевдонимИсточника) > 0 Тогда
				Соединения.Добавить(Новый Структура("ИсточникСлева, ИсточникСправа, ТипСоединения, Условие", ЭлементИсточника.Источник.Псевдоним, ЭлементСоединения.Источник.Источник.Псевдоним, ЭлементСоединения.ТипСоединения, Строка(ЭлементСоединения.Условие)));
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	ОператорВыбрать.Источники.Удалить(ИндексИсточника);
	ОператорВыбрать.Отбор.Очистить();	
	Источник(МодельЗапроса, Таблица, Псевдоним);
	
	// Восстановить сохраненные поля, отборы и соединения
	Если Псевдоним <> ПсевдонимИсточника Тогда
		
		Для Каждого ЭлементСоединения Из Соединения Цикл
			Соединение(МодельЗапроса, 
				СтрЗаменить(ЭлементСоединения.ИсточникСлева, ПсевдонимИсточника, Псевдоним), 
				СтрЗаменить(ЭлементСоединения.ИсточникСправа, ПсевдонимИсточника, Псевдоним), 
				СтрЗаменить(ЭлементСоединения.Условие, ПсевдонимИсточника, Псевдоним), 
				ЭлементСоединения.ТипСоединения
			);
		КонецЦикла;
		
		Для Каждого Поле Из ВыбираемыеПоля Цикл
			Попытка
				Поле(МодельЗапроса, СтрЗаменить(Поле.Выражение, ПсевдонимИсточника, Псевдоним), Поле.Псевдоним);
			Исключение
				// не все колонки могут быть в полях оператора
			КонецПопытки;
		КонецЦикла;
		
		Для каждого Отбор Из Отборы Цикл
			ОператорВыбрать.Отбор.Добавить(СтрЗаменить(Отбор, ПсевдонимИсточника, Псевдоним));
		КонецЦикла;
		
	Иначе
		
		Для каждого ЭлементСоединения Из Соединения Цикл
			Соединение(МодельЗапроса, 
				ЭлементСоединения.ИсточникСлева, 
				ЭлементСоединения.ИсточникСправа, 
				ЭлементСоединения.Условие, 
				ЭлементСоединения.ТипСоединения
			);
		КонецЦикла;
		
		Для каждого Поле Из ВыбираемыеПоля Цикл
			Попытка
				Поле(МодельЗапроса, Поле.Выражение, Поле.Псевдоним);
			Исключение
				// не все колонки могут быть в полях оператора
			КонецПопытки;
		КонецЦикла;
		
		Для каждого Отбор Из Отборы Цикл
			ОператорВыбрать.Отбор.Добавить(Отбор);
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры

Процедура ДоступноеПоле(МодельЗапроса, Имя, Тип = Неопределено) Экспорт
	// Поскольку тип Строка нельзя ограничить (нет квалификатора строки как у типа значения),
	// то используется тип Неопределено.
	// Это нужно для того, чтобы не возникало фантомной ошибки
	// в условиях отбора и соединения: нельзя использовать поля неограниченной длины
	МодельЗапроса.ДоступныеПоля.Добавить(Имя, ?(Тип = Тип("Строка"), Неопределено, Тип));
КонецПроцедуры

