// Группировка для итогов
// 
// Параметры:
//  Выражение - Строка - Выражение
//  ИмяКолонки - Строка - Имя колонки
//  ТипКонтрольнойТочки - ТипКонтрольнойТочкиСхемыЗапроса, Неопределено - Тип контрольной точки
//                        Иерархия, ТолькоИерархия, Элементы
Процедура Группировка(МодельЗапроса, Выражение, ИмяКолонки = "", ТипКонтрольнойТочки = Неопределено, ТипДополненияПериодами = Неопределено, НачалоПериода = "", КонецПериода = "") Экспорт
	КонтрольнаяТочка = МодельЗапроса.ЗапросПакета.КонтрольныеТочкиИтогов.Добавить(Выражение);
	КонтрольнаяТочка.ИмяКолонки					= ИмяКолонки;
	КонтрольнаяТочка.ТипКонтрольнойТочки 		= ?(ТипКонтрольнойТочки 	= Неопределено, ТипКонтрольнойТочкиСхемыЗапроса.Элементы, ТипКонтрольнойТочки);
	КонтрольнаяТочка.ТипДополненияПериодами 	= ?(ТипДополненияПериодами 	= Неопределено, ТипДополненияПериодамиСхемыЗапроса.БезДополнения, ТипДополненияПериодами);
	КонтрольнаяТочка.НачалоПериодаДополнения 	= ?(ТипЗнч(НачалоПериода) 	= Тип("Строка"), НачалоПериода, ФорматДатаВремя(НачалоПериода));
	КонтрольнаяТочка.КонецПериодаДополнения 	= ?(ТипЗнч(КонецПериода) 	= Тип("Строка"), КонецПериода, ФорматДатаВремя(КонецПериода));
	МодельЗапроса.КонтрольнаяТочка = КонтрольнаяТочка;
КонецПроцедуры

// Группировки для итогов
// 
// Параметры:
//  Выражения - Массив из Строка - Выражения группировок итогов в формате "Выражение КАК Псевдоним", "Выражение"
// 
// Возвращаемое значение:
//  ОбработкаОбъект.МодельЗапроса
Процедура Группировки(МодельЗапроса,Выражения) Экспорт
	МассивВыражений = ?(ТипЗнч(Выражения) = Тип("Массив"), Выражения, СтрРазделить(Выражения, ","));
	Для Каждого ВыражениеПоля Из МассивВыражений Цикл
		ПозицияТокена = СтрНайти(ВРег(ВыражениеПоля), " КАК ");
		Если ПозицияТокена = 0 Тогда
			Псевдоним = "";
			Выражение = ВыражениеПоля;
		Иначе
			Выражение = Лев(ВыражениеПоля, ПозицияТокена - 1);
			Псевдоним = Прав(ВыражениеПоля, СтрДлина(ВыражениеПоля) - ПозицияТокена - 4);
		КонецЕсли;			
		Группировка(МодельЗапроса, Выражение, Псевдоним);
	КонецЦикла;
КонецПроцедуры

Процедура Итоги(МодельЗапроса, Выражения) Экспорт
	МассивВыражений = ?(ТипЗнч(Выражения) = Тип("Массив"), Выражения, СтрРазделить(Выражения, ","));
	Для Каждого ВыражениеПоля Из МассивВыражений Цикл
		ПозицияТокена = СтрНайти(ВРег(ВыражениеПоля), " КАК ");
		Если ПозицияТокена = 0 Тогда
			Псевдоним = "";
			Выражение = ВыражениеПоля;
		Иначе
			Выражение = Лев(ВыражениеПоля, ПозицияТокена - 1);
			Псевдоним = Прав(ВыражениеПоля, СтрДлина(ВыражениеПоля) - ПозицияТокена - 4);
		КонецЕсли;			
		Итог(МодельЗапроса, Выражение, Псевдоним);
	КонецЦикла;
КонецПроцедуры

// Дополнение результата запроса датами в установленном периоде
// https://its.1c.ru/db/metod8dev/content/2660/hdoc
Процедура ПоПериодам(МодельЗапроса, ТипДополненияПериодами, НачалоПериода = "", КонецПериода = "") Экспорт
	КонтрольнаяТочка = МодельЗапроса.КонтрольнаяТочка;
	КонтрольнаяТочка.ТипДополненияПериодами = ?(ТипДополненияПериодами = Неопределено, ТипДополненияПериодамиСхемыЗапроса.БезДополнения, ТипДополненияПериодами);
	КонтрольнаяТочка.НачалоПериодаДополнения = ?(ТипЗнч(НачалоПериода) = Тип("Строка"), НачалоПериода, ФорматДатаВремя(НачалоПериода));
	КонтрольнаяТочка.КонецПериодаДополнения = ?(ТипЗнч(КонецПериода) = Тип("Строка"), КонецПериода, ФорматДатаВремя(КонецПериода));
КонецПроцедуры

Процедура ОбщиеИтоги(МодельЗапроса) Экспорт
	МодельЗапроса.ЗапросПакета.ОбщиеИтоги = Истина;
КонецПроцедуры

#КонецОбласти

#Область Оператор

// Оператор
// 
// Параметры:
//  МодельЗапроса - См. НовыйМодельЗапросаПараметры
//  Количество - Число, Неопределено - количество записей
//  Различные - Булево, Неопределено - уникальные записи
//  ТипОбъединения - ТипОбъединенияСхемыЗапроса, Неопределено - Тип объединения
//  ИндексКопии - Неопределено - Индекс копии оператора. Если указан, то будет добавлена копия оператора по индексу. 
//               Допускается указывать отностельный индекс со знаком "-", например -1 - предыдущий оператор
Процедура Выбрать(МодельЗапроса, Количество = Неопределено, Различные = Неопределено, ТипОбъединения = Неопределено, ИндексКопии = Неопределено) Экспорт
	
	ЗапросПакета = МодельЗапроса.ЗапросПакета;
	
	Если ИндексКопии <> Неопределено Тогда
		Если ТипЗнч(ИндексКопии) = Тип("Число") Тогда
			Если ИндексКопии < 0 Тогда
				ОператорИсточник = ЗапросПакета.Операторы[ЗапросПакета.Операторы.Количество() + ИндексКопии];
			Иначе
				ОператорИсточник = ЗапросПакета.Операторы[ИндексКопии];
			КонецЕсли;
		ИначеЕсли ТипЗнч(ИндексКопии) = Тип("ОператорВыбратьСхемыЗапроса") Тогда
			ОператорИсточник = ИндексКопии;
		Иначе
			ВызватьИсключение "Неизвестный тип оператора-источника: " + ТипЗнч(ИндексКопии);
		КонецЕсли;
		ОператорВыбрать = ЗапросПакета.Операторы.Добавить(ОператорИсточник);
	Иначе
		Если ЗапросПакета.Операторы.Количество() = 1 Тогда
			ОператорВыбрать = ЗапросПакета.Операторы[0];
			Если НЕ ОператорВыбрать.Источники.Количество() = 0 ИЛИ НЕ ОператорВыбрать.ВыбираемыеПоля.Количество() = 0 Тогда
				ОператорВыбрать = ЗапросПакета.Операторы.Добавить();
			КонецЕсли;
		Иначе
			ОператорВыбрать = ЗапросПакета.Операторы.Добавить();
		КонецЕсли; 
	КонецЕсли;
	
	Если Количество <> Неопределено Тогда
		ОператорВыбрать.КоличествоПолучаемыхЗаписей = Количество;
	КонецЕсли;
	
	Если Различные <> Неопределено Тогда
		ОператорВыбрать.ВыбиратьРазличные = Различные;
	КонецЕсли;
	
	ОператорВыбрать.ТипОбъединения = ?(ТипОбъединения = Неопределено, ТипОбъединенияСхемыЗапроса.ОбъединитьВсе, ТипОбъединения);
	МодельЗапроса.ИндексОператора = ЗапросПакета.Операторы.Индекс(ОператорВыбрать);
	МодельЗапроса.ВыбираемыеПоля = ОператорВыбрать.ВыбираемыеПоля;
	МодельЗапроса.ОператорВыбрать = ОператорВыбрать;
	
КонецПроцедуры

// Создание оператора выборки. См. Выбрать
// 
Процедура Объединить(МодельЗапроса, Количество = Неопределено, Различные = Неопределено, ТипОбъединения = Неопределено, ИндексКопии = Неопределено) Экспорт
	Выбрать(МодельЗапроса, Количество, Различные, ?(ТипОбъединения = Неопределено, ТипОбъединенияСхемыЗапроса.Объединить, ТипОбъединения), ИндексКопии);
КонецПроцедуры

// Создание оператора выборки. См. Выбрать
// 
Процедура ОбъединитьВсе(МодельЗапроса, Количество = Неопределено, Различные = Неопределено, ИндексКопии = Неопределено) Экспорт
	Выбрать(МодельЗапроса, Количество, Различные, ТипОбъединенияСхемыЗапроса.ОбъединитьВсе, ИндексКопии);
КонецПроцедуры

// Добавить поле в операторе выбора
// 
// Параметры:
//  Выражение - Строка - Выражение
//  Псевдоним - Строка - Псевдоним
//  ВыражениеЕстьNull - Строка - Выражение есть null
Процедура Поле(МодельЗапроса, Знач Выражение, Знач Псевдоним = "", ВыражениеЕстьNull = "") Экспорт
	Перем Поле;
	
	Если ТипЗнч(Выражение) <> Тип("Строка") Тогда
		ИмяПараметра = ОбщийКлиентСервер.ИмяПоУникальномуИдентификатору();
		Параметр(МодельЗапроса, ИмяПараметра, Выражение);
		Поле(МодельЗапроса, "&" + ИмяПараметра, Псевдоним, ВыражениеЕстьNull);
		Возврат;
	КонецЕсли;
	
	ЗапросПакета = МодельЗапроса.ЗапросПакета;
	ОператорВыбрать = МодельЗапроса.ОператорВыбрать;
	ИндексОператора = МодельЗапроса.ИндексОператора;
	ВыбираемыеПоля	= МодельЗапроса.ВыбираемыеПоля;
	Колонки = ЗапросПакета.Колонки;

	Если СтрЗаканчиваетсяНа(Выражение, "*") Тогда
		ПозицияТочки = СтрНайти(Выражение, ".");
		Если ПозицияТочки = 0 Тогда // поля по всем источникам, доступным из оператора
			Для каждого Источник Из ОператорВыбрать.Источники Цикл
				ПсевдонимИсточника = Источник.Источник.Псевдоним;
				Для каждого ДоступноеПоле Из Источник.Источник.ДоступныеПоля Цикл
					мПутьКПолю = ПсевдонимИсточника + "." + ДоступноеПоле.Имя;
					Колонка = Колонки.Найти(ДоступноеПоле.Имя);
					Если ВыбираемыеПоля.Найти(мПутьКПолю) <> Неопределено ИЛИ Колонка <> Неопределено И Колонка.Поля[ИндексОператора] <> Неопределено Тогда
						Продолжить;
					КонецЕсли;
					Если ТипЗнч(ДоступноеПоле) = Тип("ДоступноеПолеСхемыЗапроса") Тогда
						Если Колонка <> Неопределено Тогда
							Поле = ВыбираемыеПоля.Добавить(мПутьКПолю, Колонки.Индекс(Колонка));
						Иначе
							Поле = ВыбираемыеПоля.Добавить(мПутьКПолю);
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		Иначе// поля из указанного до точки источником
			ПсевдонимИсточника = Лев(Выражение, ПозицияТочки-1);
			Для каждого ДоступноеПоле Из ОператорВыбрать.Источники.НайтиПоПсевдониму(ПсевдонимИсточника).Источник.ДоступныеПоля Цикл
				мПутьКПолю = ПсевдонимИсточника + "." + ДоступноеПоле.Имя;
				Колонка = Колонки.Найти(ДоступноеПоле.Имя);
				Если ВыбираемыеПоля.Найти(мПутьКПолю) <> Неопределено ИЛИ Колонка <> Неопределено И Колонка.Поля[ИндексОператора] <> Неопределено Тогда
					Продолжить;
				КонецЕсли;
				Если ТипЗнч(ДоступноеПоле) = Тип("ДоступноеПолеСхемыЗапроса") Тогда
					Если Колонка <> Неопределено Тогда
						Поле = ВыбираемыеПоля.Добавить(мПутьКПолю, Колонки.Индекс(Колонка));
					Иначе
						Поле = ВыбираемыеПоля.Добавить(мПутьКПолю);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	Иначе
		Если ЗначениеЗаполнено(ВыражениеЕстьNull) Тогда
			// Замена дефолтного псевдонима
			Если НЕ ЗначениеЗаполнено(Псевдоним) Тогда
				Псевдоним = Псевдоним(Выражение, Псевдоним);
			КонецЕсли;
			Выражение = СтрШаблон("ЕСТЬNULL(%1, %2)", Выражение, ВыражениеЕстьNull);
		КонецЕсли;
		ИндексКолонки = Неопределено;
		Если НЕ ПустаяСтрока(Псевдоним) Тогда // найти индекс колонки по псевдониму
			Колонка = Колонки.Найти(Псевдоним);
			Если Колонка <> Неопределено Тогда
				ИндексКолонки = Колонки.Индекс(Колонка);
			КонецЕсли;
		КонецЕсли;
		Если ИндексКолонки = Неопределено Тогда
			Если ИндексОператора > 0 И НЕ ПустаяСтрока(Псевдоним) Тогда
				//  Добавление колонки Null, чтобы добавить поле в существующий индекс добавленной колонки
				ЗапросПакета.Операторы[0].ВыбираемыеПоля.Добавить("Null");
				ИндексКолонки = Колонки.Количество() - 1;
				Колонки[ИндексКолонки].Псевдоним = Псевдоним;
				Поле = ВыбираемыеПоля.Добавить(Выражение, ИндексКолонки);
			Иначе
				Поле = ВыбираемыеПоля.Добавить(Выражение);
				Если НЕ ПустаяСтрока(Псевдоним) Тогда
					ИндексКолонки = Колонки.Количество() - 1;
					Колонки[ИндексКолонки].Псевдоним = Псевдоним;
				КонецЕсли; 
			КонецЕсли;
		Иначе
			Поле = ВыбираемыеПоля.Добавить(Выражение, ИндексКолонки);
			Если НЕ ПустаяСтрока(Псевдоним) Тогда
				Колонки[ИндексКолонки].Псевдоним = Псевдоним;// восстановление псевдонима, который сбрасывается при добавлении поля по дефолту
			КонецЕсли; 
		КонецЕсли; 
	КонецЕсли;
	
	МодельЗапроса.Поле = Поле;

КонецПроцедуры

Процедура Автопорядок(МодельЗапроса, Значение = Истина) Экспорт
	МодельЗапроса.ЗапросПакета.Автопорядок = Значение;
КонецПроцедуры

Процедура Порядок(МодельЗапроса, Выражение, Знач Направление = Неопределено) Экспорт
	
	Если ТипЗнч(Направление) = Тип("Строка") Тогда
		Если Направление = "-" Тогда
			Направление = НаправлениеПорядкаСхемыЗапроса.ПоУбыванию;
		ИначеЕсли Направление = "+" Тогда
			Направление = НаправлениеПорядкаСхемыЗапроса.ПоВозрастанию;
		Иначе
			ВызватьИсключение СтрШаблон("Некорректное значение параметра Направление: %1", Направление);
		КонецЕсли;
	КонецЕсли;
					
	ВыражениеПорядка = МодельЗапроса.ЗапросПакета.Порядок.Добавить(Выражение);
	ВыражениеПорядка.Направление = ?(Направление = Неопределено, НаправлениеПорядкаСхемыЗапроса.ПоВозрастанию, Направление);
	
КонецПроцедуры

// Добавить условие отбора в оператор выбора
// 
// Параметры:
//  Выражение - Строка, ВыраженияСхемыЗапроса - выражение отбора, соответствует выражению ГДЕ
// 
// Возвращаемое значение:
//  ОбработкаОбъект.МодельЗапроса
Процедура Отбор(МодельЗапроса, Выражение, Действует = Истина) Экспорт
	Если НЕ Действует Тогда
		Возврат;
	КонецЕсли;
	МодельЗапроса.ОператорВыбрать.Отбор.Добавить(Выражение);
КонецПроцедуры

#КонецОбласти

#Область ВиртуальнаяТаблица

Функция ПараметрыВиртуальнойТаблицы(ИмяТаблицы, Параметры = Неопределено) Экспорт
	МассивСлов						= СтрРазделить(ИмяТаблицы, ".");
	ОбобщенноеИмяВиртуальнойТаблицы	= ВРег(МассивСлов[0]+"."+МассивСлов[МассивСлов.ВГраница()]);
	Если 		ОбобщенноеИмяВиртуальнойТаблицы = "РЕГИСТРНАКОПЛЕНИЯ.ОБОРОТЫ" Тогда
		ОписаниеПараметров = "НачалоПериода,КонецПериода,Периодичность,Условие";
	ИначеЕсли 	ОбобщенноеИмяВиртуальнойТаблицы = "РЕГИСТРСВЕДЕНИЙ.СРЕЗПЕРВЫХ"
		ИЛИ 	ОбобщенноеИмяВиртуальнойТаблицы = "РЕГИСТРСВЕДЕНИЙ.СРЕЗПОСЛЕДНИХ" 
		ИЛИ 	ОбобщенноеИмяВиртуальнойТаблицы = "РЕГИСТРНАКОПЛЕНИЯ.ОСТАТКИ" Тогда
		ОписаниеПараметров = "Период,Условие";
	ИначеЕсли 	ОбобщенноеИмяВиртуальнойТаблицы = "РЕГИСТРНАКОПЛЕНИЯ.ОСТАТКИИОБОРОТЫ" Тогда
		ОписаниеПараметров = "НачалоПериода,КонецПериода,Периодичность,МетодДополненияПериодов,Условие";
	ИначеЕсли 	ОбобщенноеИмяВиртуальнойТаблицы = "РЕГИСТРБУХГАЛТЕРИИ.ОСТАТКИ" Тогда
		ОписаниеПараметров = "Период,УсловиеСчета,Субконто,Условие";
	ИначеЕсли 	ОбобщенноеИмяВиртуальнойТаблицы = "РЕГИСТРБУХГАЛТЕРИИ.ДВИЖЕНИЯССУБКОНТО" Тогда
		ОписаниеПараметров = "НачалоПериода,КонецПериода,Условие,Порядок,Первые";
	ИначеЕсли 	ОбобщенноеИмяВиртуальнойТаблицы = "РЕГИСТРБУХГАЛТЕРИИ.ОБОРОТЫ" Тогда
		ОписаниеПараметров = "НачалоПериода,КонецПериода,Периодичность,УсловиеСчета,Субконто,Условие,УсловиеКорСчета,КорСубконто";
	ИначеЕсли 	ОбобщенноеИмяВиртуальнойТаблицы = "РЕГИСТРБУХГАЛТЕРИИ.ОБОРОТЫДТКТ" Тогда
		ОписаниеПараметров = "НачалоПериода,КонецПериода,Периодичность,УсловиеСчетаДт,СубконтоДт,УсловиеСчетаКт,СубконтоКт,Условие";
	ИначеЕсли 	ОбобщенноеИмяВиртуальнойТаблицы = "РЕГИСТРБУХГАЛТЕРИИ.ОСТАТКИИОБОРОТЫ" Тогда
		ОписаниеПараметров = "НачалоПериода,КонецПериода,Периодичность,МетодДополненияПериодов,УсловиеСчета,Субконто,Условие";
	ИначеЕсли 	ОбобщенноеИмяВиртуальнойТаблицы = "РЕГИСТРРАСЧЕТА.ФАКТИЧЕСКИЙПЕРИОДДЕЙСТВИЯ"
		Или 	ОбобщенноеИмяВиртуальнойТаблицы = "РЕГИСТРРАСЧЕТА.ДАННЫЕГРАФИКА"	Тогда
		ОписаниеПараметров = "Условие";
	ИначеЕсли 	СтрНачинаетсяС(ОбобщенноеИмяВиртуальнойТаблицы, "РЕГИСТРРАСЧЕТА.БАЗА") Тогда
		ОписаниеПараметров = "ИзмеренияОсновногоРегистра,ИзмеренияБазовогоРегистра,Разрезы,Условие";
	ИначеЕсли 	ОбобщенноеИмяВиртуальнойТаблицы = "ЗАДАЧА.ЗАДАЧИПОИСПОЛНИТЕЛЮ" Тогда
		ОписаниеПараметров = "Условие,Исполнитель";
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	МассивПараметров	= СтрРазделить(ОписаниеПараметров, ",");
	СтруктураПараметров	= Новый Структура;
	Если Параметры = Неопределено Тогда
		Для Индекс = 0 По МассивПараметров.ВГраница() Цикл
			СтруктураПараметров.Вставить(МассивПараметров[Индекс], Индекс);
		КонецЦикла;
	Иначе
		Для Индекс = 0 По МассивПараметров.ВГраница() Цикл
			Выражение = Строка(Параметры[Индекс].Выражение);
			Если ПустаяСтрока(Выражение) Тогда
				Продолжить;
			КонецЕсли;
			СтруктураПараметров.Вставить(МассивПараметров[Индекс], ОбщийКлиентСервер.ЭкранироватьТекст(Выражение));
		КонецЦикла;
	КонецЕсли;
	Возврат ?(СтруктураПараметров.Количество() = 0, Неопределено, СтруктураПараметров);
КонецФункции

