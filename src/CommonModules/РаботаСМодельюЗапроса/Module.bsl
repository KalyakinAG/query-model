#Область Результат

Функция Результат(МодельЗапроса, Индекс = Неопределено) Экспорт
	Если Индекс = Неопределено Тогда
		Возврат МодельЗапроса.Результат[МодельЗапроса.Результат.ВГраница()];
	КонецЕсли;
	Если ТипЗнч(Индекс) = Тип("Число") Тогда
		Возврат МодельЗапроса.Результат[Индекс];
	КонецЕсли;
	Возврат МодельЗапроса.Результат[МодельЗапроса.ИндексРезультата[Индекс]];
КонецФункции

Функция ВыбратьРезультат(МодельЗапроса, Индекс = Неопределено, ТипОбхода = Неопределено, Группировки = Неопределено, ГруппировкиДляЗначенийГруппировок = Неопределено) Экспорт
	Результат = Результат(МодельЗапроса, Индекс);
	Если ТипОбхода = Неопределено Тогда
		Выборка = Результат.Выбрать(ОбходРезультатаЗапроса.Прямой, Группировки, ГруппировкиДляЗначенийГруппировок);
	Иначе
		Выборка = Результат.Выбрать(ТипОбхода, Группировки, ГруппировкиДляЗначенийГруппировок);
	КонецЕсли;
	Возврат Выборка;
КонецФункции

Функция ВыгрузитьРезультат(МодельЗапроса, Индекс = Неопределено) Экспорт
	Возврат Результат(МодельЗапроса, Индекс).Выгрузить();
КонецФункции

Функция ВыбратьПервый(МодельЗапроса, Индекс = Неопределено, ТипОбхода = Неопределено, Группировки = Неопределено, ГруппировкиДляЗначенийГруппировок = Неопределено) Экспорт
	Выборка = ВыбратьРезультат(МодельЗапроса, Индекс, ТипОбхода, Группировки, ГруппировкиДляЗначенийГруппировок);
	МодельЗапроса.Выбран = Выборка.Следующий();
	Возврат Выборка;
КонецФункции

Функция Выбран(МодельЗапроса) Экспорт
	Возврат МодельЗапроса.Выбран;
КонецФункции

Функция ТекстЗапроса(МодельЗапроса, ИмяЗапроса = Неопределено) Экспорт
	Перем Индекс;
	
	СхемаЗапроса = МодельЗапроса.СхемаЗапроса;
	
	Если НЕ ЗначениеЗаполнено(ИмяЗапроса) Тогда
		Возврат СхемаЗапроса.ПолучитьТекстЗапроса();
	КонецЕсли;
	
	МодельЗапроса.ИндексЗапроса.Свойство(ИмяЗапроса, Индекс);
	
	Если Индекс = Неопределено Тогда
		ВызватьИсключение "Не найден текст запроса по имени " + ИмяЗапроса;
	КонецЕсли;
	
	Возврат СхемаЗапроса.ПакетЗапросов[Индекс].ПолучитьТекстЗапроса();
	
КонецФункции

Функция Запрос(МодельЗапроса) Экспорт
	
	МенеджерВременныхТаблиц = МодельЗапроса.МенеджерВременныхТаблиц;
	
	Если МенеджерВременныхТаблиц = Неопределено Тогда
		МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();
		МодельЗапроса.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = МодельЗапроса.СхемаЗапроса.ПолучитьТекстЗапроса();
	
	Для Каждого ЭлементПараметра Из МодельЗапроса.Параметры Цикл
		Запрос.Параметры.Вставить(ЭлементПараметра.Ключ, ЭлементПараметра.Значение);
	КонецЦикла;

	МодельЗапроса.Запрос = Запрос;
	Возврат Запрос;
	
КонецФункции

Функция ВыполнитьЗапрос(МодельЗапроса) Экспорт

	Запрос = Запрос(МодельЗапроса);	
	МодельЗапроса.Результат = Запрос.ВыполнитьПакет();
	МодельЗапроса.ИндексРезультата = МодельЗапроса.ИндексЗапроса;
	ЗаполнитьЗначенияСвойств(МодельЗапроса, НовыйМодельЗапроса(), , "Запрос, Параметры, Результат, ИндексРезультата, МенеджерВременныхТаблиц");
	Возврат МодельЗапроса.Результат;

КонецФункции

Процедура Параметр(МодельЗапроса, Имя, Значение) Экспорт
	МодельЗапроса.Параметры.Вставить(Имя, Значение);
КонецПроцедуры

