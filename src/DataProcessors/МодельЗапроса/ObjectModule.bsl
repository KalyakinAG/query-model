#Область Конструктор

// Новый модель запроса
// 
// Возвращаемое значение:
//  Структура - Новый модель запроса:
// * СхемаЗапроса - СхемаЗапроса
// * Стек - Массив из Структура
// 
// * ЗапросПакета - ЗапросВыбораСхемыЗапроса, ЗапросУничтоженияТаблицыСхемыЗапроса -
// * ВложенныйЗапрос - ЗапросВыбораСхемыЗапроса -
// * ОператорВыбрать - ОператорВыбратьСхемыЗапроса -
// * Источник - ИсточникСхемыЗапроса -
// * Соединение - СоединениеИсточникаЗапросаСхемыЗапроса -
// * ТипСоединения - ТипСоединенияСхемыЗапроса -
// * ИсточникСлева - ИсточникСхемыЗапроса -
// * ИсточникСправа - ИсточникСхемыЗапроса -
// 
// * Поле - ВыражениеСхемыЗапроса -
// * КонтрольнаяТочка - КонтрольнаяТочкаИтоговСхемыЗапроса -
// 
// * МенеджерВременныхТаблиц - МенеджерВременныхТаблиц -
// * Параметры - Структура
// 
// * СтруктураЗапроса - Структура
// * Запрос - Запрос
// * РезультатПакета - РезультатЗапроса
// * Выбран - Булево
Функция НовыйМодельЗапроса() Экспорт
	
	МодельЗапроса = Новый Структура;
	МодельЗапроса.Вставить("СхемаЗапроса", Новый СхемаЗапроса);
	МодельЗапроса.Вставить("Стек", Новый Массив);
	// Запрос
	МодельЗапроса.Вставить("ЗапросПакета");
	МодельЗапроса.Вставить("ВложенныйЗапрос");
	МодельЗапроса.Вставить("ОператорВыбрать");
	МодельЗапроса.Вставить("ИндексЗапроса", Новый Структура);
	
	МодельЗапроса.Вставить("ИндексОператора");
	МодельЗапроса.Вставить("ВыбираемыеПоля");
	МодельЗапроса.Вставить("Колонки");
	// Источник
	МодельЗапроса.Вставить("Источник");
	МодельЗапроса.Вставить("ДоступныеПоля");
	// Соединение
	МодельЗапроса.Вставить("ИсточникСлева");
	МодельЗапроса.Вставить("ИсточникСправа");
	МодельЗапроса.Вставить("Соединение");
	МодельЗапроса.Вставить("ТипСоединения");
	// Поле
	МодельЗапроса.Вставить("Поле");
	МодельЗапроса.Вставить("КонтрольнаяТочка");
	// Параметры и менеджер ВТ
	МодельЗапроса.Вставить("МенеджерВременныхТаблиц");
	МодельЗапроса.Вставить("Параметры", Новый Структура);
	// Результат
	МодельЗапроса.Вставить("Запрос");
	МодельЗапроса.Вставить("Результат");
	МодельЗапроса.Вставить("ИндексРезультата", Новый Структура);
	МодельЗапроса.Вставить("Выбран", Ложь);
	//@skip-check constructor-function-return-section
	Возврат МодельЗапроса;

КонецФункции

// Установить запрос.
// 
// Параметры:
//  НовыйЗапрос - Запрос
// 
// Возвращаемое значение:
//  ОбработкаОбъект.МодельЗапроса
Функция УстановитьЗапрос(НовыйЗапрос) Экспорт
	УстановитьМенеджерВременныхТаблиц(НовыйЗапрос.МенеджерВременныхТаблиц);
	УстановитьТекстЗапроса(НовыйЗапрос.Текст);
	Для Каждого ПараметрЗапроса Из НовыйЗапрос.Параметры Цикл
		Параметр(ПараметрЗапроса.Ключ, ПараметрЗапроса.Значение);
	КонецЦикла;
	Возврат ЭтотОбъект;
КонецФункции

Функция УстановитьСхемуЗапроса(НоваяСхемаЗапроса) Экспорт
	СхемаЗапроса = НоваяСхемаЗапроса;
	УстановитьЗапросПакета();
	Возврат ЭтотОбъект;
КонецФункции

Функция УстановитьМенеджерВременныхТаблиц(НовыйМенеджерВременныхТаблиц) Экспорт
	МенеджерВременныхТаблиц = НовыйМенеджерВременныхТаблиц;
	Возврат ЭтотОбъект;
КонецФункции

Функция УстановитьТекстЗапроса(ТекстЗапроса) Экспорт
	Перем ЗапросПакета;
	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	УстановитьЗапросПакета();
	ПакетЗапросов = СхемаЗапроса.ПакетЗапросов;
	Для Каждого ЗапросПакета Из ПакетЗапросов Цикл
		ИмяТаблицы = ЗапросПакета.ТаблицаДляПомещения;
		Если НЕ ЗначениеЗаполнено(ИмяТаблицы) Тогда
			Продолжить;
		КонецЕсли;
		Если ИндексЗапроса.Свойство(ИмяТаблицы) Тогда
			Продолжить;
		КонецЕсли;
		ИндексЗапроса.Вставить(ИмяТаблицы, ПакетЗапросов.Индекс(ЗапросПакета));
	КонецЦикла;
	Возврат ЭтотОбъект;
КонецФункции

#Область СКД

Функция УстановитьСхемуКомпоновкиДанных(Схема, Настройки) Экспорт
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновкиДанных = КомпоновщикМакета.Выполнить(Схема, Настройки);
	ТекстЗапроса = МакетКомпоновкиДанных.НаборыДанных[0].Запрос;
	УстановитьТекстЗапроса(ТекстЗапроса);
	Для Каждого ЗначениеПараметра Из МакетКомпоновкиДанных.ЗначенияПараметров Цикл
		Параметр(ЗначениеПараметра.Имя, ЗначениеПараметра.Значение);
	КонецЦикла;
	Возврат ЭтотОбъект;
КонецФункции

Функция УстановитьСхемуТаблицыСписка(ТаблицаСписка) Экспорт
	Схема = ТаблицаСписка.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
	Настройки = ТаблицаСписка.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
	// Добавить в настройку отбор по текущей строке
	ПоляКлюча = ТаблицаСписка.ТекущаяСтрока;
	Если ПоляКлюча <> Неопределено Тогда
		Для Каждого ПолеКлюча Из ПоляКлюча Цикл
			ДобавитьОтборСКД(Настройки.Отбор, ПолеКлюча.Ключ, ПолеКлюча.Значение, ВидСравненияКомпоновкиДанных.Равно, Истина);
		КонецЦикла;
	КонецЕсли;
	// Добавить в настройку доступные поля
	Настройки.Структура[0].Выбор.Элементы.Очистить();
	Для Каждого ДоступноеПоле Из Настройки.Структура[0].Выбор.ДоступныеПоляВыбора.Элементы Цикл
		Если ДоступноеПоле.Таблица ИЛИ ДоступноеПоле.Папка Тогда
			Продолжить;
		КонецЕсли;
		ДобавитьВыбранноеПолеСКД(Настройки.Структура[0].Выбор, ДоступноеПоле.Поле);
	КонецЦикла;
	// Инициировать схему с настройками
	УстановитьСхемуКомпоновкиДанных(Схема, Настройки);
	Возврат ЭтотОбъект;
КонецФункции

Функция УстановитьСхемуДинамическогоСписка(Список) Экспорт
	УстановитьТекстЗапроса(Список.ТекстЗапроса);
	Для Каждого ЭлементПараметра Из Список.Параметры.Элементы Цикл
		Параметр(Строка(ЭлементПараметра.Параметр), ЭлементПараметра.Значение);
	КонецЦикла;
	Возврат ЭтотОбъект;
КонецФункции

#КонецОбласти

#КонецОбласти

#Область Курсор

Функция УстановитьИсточник(ИндексИлиПсевдоним = Неопределено) Экспорт
	Источник = ПолучитьИсточник(ИндексИлиПсевдоним);
	Возврат ЭтотОбъект;
КонецФункции

Функция УстановитьОператор(Индекс = Неопределено) Экспорт
	Если ТипЗнч(ЗапросПакета) = Тип("ЗапросУничтоженияТаблицыСхемыЗапроса") Тогда
		Возврат ЭтотОбъект;
	КонецЕсли;
	Если Индекс = Неопределено Тогда
		ВыбранныйИндекс = ЗапросПакета.Операторы.Количество() - 1;
	Иначе
		ВыбранныйИндекс = Индекс;
	КонецЕсли;
	ОператорВыбрать = ЗапросПакета.Операторы[ВыбранныйИндекс];
	Возврат УстановитьИсточник();
КонецФункции

Функция УстановитьЗапросПакета(Индекс = Неопределено) Экспорт
	Перем ВыбранныйИндекс;
	Если Индекс = Неопределено Тогда
		ВыбранныйИндекс = СхемаЗапроса.ПакетЗапросов.Количество() - 1;
	ИначеЕсли ТипЗнч(Индекс) = Тип("Строка") Тогда
		Для Каждого Элемент Из СхемаЗапроса.ПакетЗапросов Цикл
			Если Элемент.ТаблицаДляПомещения = Индекс Тогда
				ВыбранныйИндекс = СхемаЗапроса.ПакетЗапросов.Индекс(Элемент);
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если ВыбранныйИндекс = Неопределено Тогда
			ВызватьИсключение "Не найден запрос с именем """ + Индекс + """";
		КонецЕсли;
	Иначе
		ВыбранныйИндекс = Индекс;
	КонецЕсли;
	ЗапросПакета = СхемаЗапроса.ПакетЗапросов[ВыбранныйИндекс];
	Возврат УстановитьОператор();
КонецФункции

#КонецОбласти

#Область Модификаторы

Функция УдалитьИсточник(Псевдоним) Экспорт
	Перем ИндексИсточника;
	Если ТипЗнч(Псевдоним) = Тип("Строка") Тогда
		Источник = ОператорВыбрать.Источники.НайтиПоПсевдониму(Псевдоним);
		Если Источник <> Неопределено Тогда
			ИндексИсточника = ОператорВыбрать.Источники.Индекс(Источник);
		КонецЕсли;
	ИначеЕсли ТипЗнч(Псевдоним) = Тип("Число") Тогда
		ИндексИсточника = Псевдоним;
	Иначе
		ИндексИсточника = ОператорВыбрать.Источники.Индекс(Псевдоним);
	КонецЕсли;
	Если ИндексИсточника = Неопределено Тогда
		Возврат ЭтотОбъект;
	КонецЕсли;
	ОператорВыбрать.Источники.Удалить(ИндексИсточника);
	Возврат ЭтотОбъект;
КонецФункции

Функция ЗаменитьИсточник(ПсевдонимИсточника, Таблица, НовыйПсевдоним = "") Экспорт
	
	Если ПустаяСтрока(НовыйПсевдоним) Тогда
		Псевдоним = ПсевдонимИсточника;
	КонецЕсли;
	
	ИндексОператора = ЗапросПакета.Операторы.Индекс(ОператорВыбрать);
	Источник = ОператорВыбрать.Источники.НайтиПоПсевдониму(ПсевдонимИсточника);
	ИндексИсточника = ОператорВыбрать.Источники.Индекс(Источник);
	
	// Сохранить все поля запроса
	ВыбираемыеПоля  = Новый Массив;
	Для Каждого Колонка Из ЗапросПакета.Колонки Цикл
		Выражение =  Строка(Колонка.Поля[ИндексОператора]);
		Если ПустаяСтрока(Выражение) Тогда // при нескольких объединениях часть полей может отсутствовать (NULL поля)
			Продолжить;
		КонецЕсли;
		ВыбираемыеПоля.Добавить(Новый Структура("Выражение, Псевдоним", Строка(Колонка.Поля[ИндексОператора]), Колонка.Псевдоним));
	КонецЦикла;
	
	// Сохранить все отборы
	Отборы = Новый Массив;
	Для Каждого Отбор Из ОператорВыбрать.Отбор Цикл
		Отборы.Добавить(Строка(Отбор));
	КонецЦикла;
	
	// Сохранить все соединения с источником
	Соединения = Новый Массив;
	Для Каждого ЭлементИсточника Из ОператорВыбрать.Источники Цикл
		Для Каждого ЭлементСоединения Из ЭлементИсточника.Соединения Цикл
			Если СтрНайти(ЭлементСоединения.Условие, ПсевдонимИсточника) > 0 Тогда
				Соединения.Добавить(Новый Структура("ИсточникСлева, ИсточникСправа, ТипСоединения, Условие", ЭлементИсточника.Источник.Псевдоним, ЭлементСоединения.Источник.Источник.Псевдоним, ЭлементСоединения.ТипСоединения, Строка(ЭлементСоединения.Условие)));
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	ОператорВыбрать.Источники.Удалить(ИндексИсточника);
	ОператорВыбрать.Отбор.Очистить();	
	Источник(Таблица, Псевдоним);
	
	// Восстановить сохраненные поля, отборы и соединения
	Если Псевдоним <> ПсевдонимИсточника Тогда
		
		Для Каждого ЭлементСоединения Из Соединения Цикл
			Соединение(
				СтрЗаменить(ЭлементСоединения.ИсточникСлева, ПсевдонимИсточника, Псевдоним), 
				СтрЗаменить(ЭлементСоединения.ИсточникСправа, ПсевдонимИсточника, Псевдоним), 
				СтрЗаменить(ЭлементСоединения.Условие, ПсевдонимИсточника, Псевдоним), 
				ЭлементСоединения.ТипСоединения
			);
		КонецЦикла;
		
		Для Каждого Поле Из ВыбираемыеПоля Цикл
			//@skip-check empty-except-statement
			Попытка
				Поле(СтрЗаменить(Поле.Выражение, ПсевдонимИсточника, Псевдоним), Поле.Псевдоним);
			Исключение
				// не все колонки могут быть в полях оператора
			КонецПопытки;
		КонецЦикла;
		
		Для Каждого Отбор Из Отборы Цикл
			ОператорВыбрать.Отбор.Добавить(СтрЗаменить(Отбор, ПсевдонимИсточника, Псевдоним));
		КонецЦикла;
		
	Иначе
		
		Для Каждого ЭлементСоединения Из Соединения Цикл
			Соединение( 
				ЭлементСоединения.ИсточникСлева, 
				ЭлементСоединения.ИсточникСправа, 
				ЭлементСоединения.Условие, 
				ЭлементСоединения.ТипСоединения
			);
		КонецЦикла;
		
		Для Каждого Поле Из ВыбираемыеПоля Цикл
			Попытка
				Поле(Поле.Выражение, Поле.Псевдоним);
			Исключение
				// не все колонки могут быть в полях оператора
			КонецПопытки;
		КонецЦикла;
		
		Для Каждого Отбор Из Отборы Цикл
			ОператорВыбрать.Отбор.Добавить(Отбор);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ЭтотОбъект;
	
КонецФункции

Функция УдалитьКолонку(Псевдоним) Экспорт
	Колонки = ЗапросПакета.Колонки;
	Колонка = Колонки.Найти(Псевдоним);
	Если Колонка = Неопределено Тогда
		Возврат ЭтотОбъект;
	КонецЕсли;
	Колонки.Удалить(Колонки.Индекс(Колонка));
	Возврат ЭтотОбъект;
КонецФункции

Функция УдалитьПоле(Выражение) Экспорт
	ВыбираемыеПоля = ОператорВыбрать.ВыбираемыеПоля;
	Поле = ВыбираемыеПоля.Найти(Выражение);
	Если Поле = Неопределено Тогда
		Возврат ЭтотОбъект;
	КонецЕсли;
	ВыбираемыеПоля.Удалить(ВыбираемыеПоля.Индекс(Поле));
	Возврат ЭтотОбъект;
КонецФункции

Функция ОчиститьОтбор() Экспорт
	ОператорВыбрать.Отбор.Очистить();
	Возврат ЭтотОбъект;
КонецФункции

Функция ОчиститьГруппировки() Экспорт
	ОператорВыбрать.Группировки.Очистить();
	ОператорВыбрать.Группировка.Очистить();
	Возврат ЭтотОбъект;
КонецФункции

Функция ОчиститьИтоги() Экспорт
	ЗапросПакета.ОбщиеИтоги = Ложь;
	ЗапросПакета.ВыраженияИтогов.Очистить();
	ЗапросПакета.КонтрольныеТочкиИтогов.Очистить();
	Возврат ЭтотОбъект;
КонецФункции

Функция ОчиститьСоединения() Экспорт
	Для Каждого Источник Из ОператорВыбрать.Источники Цикл
		Источник.Соединения.Очистить();
	КонецЦикла;
	Возврат ЭтотОбъект;
КонецФункции

#КонецОбласти

#Область ЗапросПакета

// Сброс и очистка результата и временных таблиц
// 
// Возвращаемое значение:
//  ОбработкаОбъект.МодельЗапроса
Функция Очистить() Экспорт
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, НовыйМодельЗапроса(), , "Запрос, Параметры, Результат, ИндексРезультата, МенеджерВременныхТаблиц");
	Возврат ЭтотОбъект;
КонецФункции

Функция Разрешенные(ВыбиратьРазрешенные = Истина) Экспорт
	ЗапросПакета.ВыбиратьРазрешенные = ВыбиратьРазрешенные;
	Возврат ЭтотОбъект;
КонецФункции

Функция ВременныеТаблицы() Экспорт
	ГруппаВременныеТаблицы = СхемаЗапроса.ПакетЗапросов[СхемаЗапроса.ПакетЗапросов.Количество() - 1].ДоступныеТаблицы.Найти("Временные таблицы");
	Если ГруппаВременныеТаблицы = Неопределено Тогда
		Возврат Новый Массив;
	КонецЕсли;
	Возврат ГруппаВременныеТаблицы.Состав;
КонецФункции

Функция Поместить(ИмяВременнойТаблицы) Экспорт
	ЗапросПакета.ТаблицаДляПомещения = ИмяВременнойТаблицы;
	Возврат ЭтотОбъект;
КонецФункции

Функция Добавить(ИмяВременнойТаблицы) Экспорт
	ЗапросПакета.ТаблицаДляДобавления = ИмяВременнойТаблицы;
	Возврат ЭтотОбъект;
КонецФункции

Функция Уничтожить(ИмяВременнойТаблицы) Экспорт
	ПакетЗапросов = СхемаЗапроса.ПакетЗапросов;
	Если ПакетЗапросов.Количество() = 1 И СхемаЗапроса.ПолучитьТекстЗапроса() = "" Тогда
		ПакетЗапросов.Очистить();
	КонецЕсли;
	ЗапросПакета = СхемаЗапроса.ПакетЗапросов.Добавить(Тип("ЗапросУничтоженияТаблицыСхемыЗапроса"));
	ЗапросПакета.ИмяТаблицы = ИмяВременнойТаблицы;
	Возврат ЭтотОбъект;
КонецФункции

// Описание запроса.
// 
// Параметры:
//   - см. НовыйМодельЗапроса
//  ИмяЗапроса - Строка - Имя запроса
Функция УстановитьИмяЗапроса(ИмяЗапроса) Экспорт

	Индекс = СхемаЗапроса.ПакетЗапросов.Индекс(ЗапросПакета);
	ИндексЗапроса.Вставить(ИмяЗапроса, Индекс);
	
	Возврат ЭтотОбъект;
КонецФункции

// Добавляет оператор создания нового запроса в пакете
// 
// Параметры:
//   - см. НовыйМодельЗапроса
//  ИмяЗапроса - Строка - Имя запроса, которое может быть использовано при именованном обращении к результату запроса
Функция ЗапросПакета(ИмяЗапроса = "", ИндексВставки = Неопределено, ИндексКопииИлиТекстЗапроса = Неопределено) Экспорт
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, НовыйСостояние());
	ПакетЗапросов = СхемаЗапроса.ПакетЗапросов;
	
	Если ИндексКопииИлиТекстЗапроса <> Неопределено Тогда
		Если ТипЗнч(ИндексКопииИлиТекстЗапроса) = Тип("Строка") Тогда
			Индекс = Неопределено;
			//@skip-check empty-except-statement
			Попытка
				ИндексЗапроса.Свойство(ИндексКопииИлиТекстЗапроса, Индекс);
			Исключение
			КонецПопытки;
			Если Индекс <> Неопределено Тогда
				ЗапросПакета = ПакетЗапросов.ДобавитьКопию(Индекс);
			Иначе
				ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
				Если ЗначениеЗаполнено(ТекстЗапроса) Тогда
					ТекстЗапроса = ТекстЗапроса + 
						ОбщегоНазначения.РазделительПакетаЗапросов() +
						ИндексКопииИлиТекстЗапроса
					;
					УстановитьТекстЗапроса(ТекстЗапроса);
				Иначе
					УстановитьТекстЗапроса(ИндексКопииИлиТекстЗапроса);
				КонецЕсли;
			КонецЕсли;
		Иначе
			ЗапросПакета = ПакетЗапросов.ДобавитьКопию(ИндексКопииИлиТекстЗапроса);
		КонецЕсли;
		ПакетЗапросов.Переместить(ЗапросПакета, ПакетЗапросов.Количество() - 1);
	Иначе
		Если ПакетЗапросов.Количество() = 1 И СхемаЗапроса.ПолучитьТекстЗапроса() = "" И ИндексВставки = Неопределено Тогда
			ЗапросПакета = ПакетЗапросов[0];//  дефолтный запрос
		Иначе
			ЗапросПакета = ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
		КонецЕсли;
	КонецЕсли;
	
	Если ИндексВставки <> Неопределено Тогда
		ПакетЗапросов.Переместить(ЗапросПакета, ИндексВставки);
		Для Каждого Элемент Из ИндексЗапроса Цикл
			Если Элемент.Значение < ИндексВставки Тогда
				Продолжить;
			КонецЕсли;
			Элемент.Значение = Элемент.Значение + 1;
		КонецЦикла;
	КонецЕсли;	
	
	Если НЕ ПустаяСтрока(ИмяЗапроса) Тогда
		УстановитьИмяЗапроса(ИмяЗапроса);
	КонецЕсли;

	Колонки = ЗапросПакета.Колонки;
	Возврат ЭтотОбъект;
КонецФункции

Функция Индекс(Поля, Уникальный = Ложь) Экспорт
	ИндексТаблицыЗапроса = ЗапросПакета.Индексы.Добавить();//ИндексыСхемыЗапроса
	ИндексТаблицыЗапроса.Уникальный = Уникальный;
	ВыраженияИндекса = ИндексТаблицыЗапроса.ВыраженияИндекса;// ВыраженияИндексаСхемыЗапроса
	Для Каждого Поле Из ОбщийКлиентСервер.Массив(Поля) Цикл
		ВыраженияИндекса.Добавить(Поле);
	КонецЦикла;
	Возврат ЭтотОбъект;
КонецФункции

#КонецОбласти

#Область Источник

Функция Источник(Таблица, Знач Псевдоним = "", ЗначениеПараметра = Неопределено) Экспорт
	
	Если ОператорВыбрать = Неопределено Тогда
		Выбрать();
	КонецЕсли;

	ТипИсточника = ТипЗнч(Таблица);
	
	Если ТипИсточника = Тип("Строка") Тогда

		Если СтрНачинаетсяС(Таблица, "{") Тогда
			//  Это таблица JSON
			ТаблицаИзJSON = РаботаСКоллекцией.СтруктураВТаблицуЗначений(Таблица);
			Источник(ТаблицаИзJSON, Псевдоним);
			Возврат ЭтотОбъект;
			
		КонецЕсли;
		
		Если СтрНачинаетсяС(Таблица, "&") Тогда
			//  Это параметр
			ПсевдонимВременнойТаблицы = Псевдоним;
			
			Если НЕ ЗначениеЗаполнено(ПсевдонимВременнойТаблицы) Тогда
				Если ЗначениеЗаполнено(ЗапросПакета.ТаблицаДляПомещения) Тогда
					ПсевдонимВременнойТаблицы = ЗапросПакета.ТаблицаДляПомещения;
				ИначеЕсли ЗначениеЗаполнено(ЗапросПакета.ТаблицаДляДобавления) Тогда
					ПсевдонимВременнойТаблицы = ЗапросПакета.ТаблицаДляДобавления;
				КонецЕсли;
			КонецЕсли;
			
			ДобавитьОписаниеВременнойТаблицы(Таблица, ПсевдонимВременнойТаблицы);
			
			Если ЗначениеПараметра <> Неопределено Тогда
				ИмяПараметра = Прав(Таблица, СтрДлина(Таблица) - 1);
				Параметр(ИмяПараметра, ЗначениеПараметра);
			КонецЕсли;
			
			Возврат ЭтотОбъект;
			
		КонецЕсли;

		ВременнаяТаблица = ?(МенеджерВременныхТаблиц <> Неопределено, МенеджерВременныхТаблиц.Таблицы.Найти(Таблица), Неопределено);
		
		Если ВременнаяТаблица <> Неопределено Тогда
			//  Это имя временной таблицы из менеджера временных таблиц
			ДобавитьОписаниеВременнойТаблицы(Таблица, Псевдоним);
			
			Для Каждого Колонка Из ВременнаяТаблица.Колонки Цикл
				// При добавлении доступного поля необходимо указать Тип, хотя фактическое значение будет иметь тип ТипЗначения.
				// Ограничения:
				// 1. Доступ к полям через точку (например, Поле.ПодПоле) поддерживается только для объектов одного типа.
				// 2. Запрещено использовать оператор ССЫЛКА.
				// Обходное решение:
				// 1. Для работы с данными разных типов используйте явные соединения таблиц вместо вложенных полей.
				// 2. Для определения типа значения используйте функцию ТипЗначения() вместо ССЫЛКА.
				ДоступноеПоле(Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
			КонецЦикла;
			
			Возврат ЭтотОбъект;
			
		КонецЕсли;
		
		//  Это имя доступной таблицы в текущей схеме запроса
		ДобавитьИсточник(Таблица, ?(ПустаяСтрока(Псевдоним), ОбщийКлиентСервер.ОкончаниеСтрокиПослеРазделителя(Таблица), Псевдоним));
		Возврат ЭтотОбъект;
		
	КонецЕсли;
	
	//  Это Таблица значений, ТабличнаяЧасть, ДанныеФормыКоллекцияЗначений
	ИмяПараметра = ОбщийКлиентСервер.ИмяПоУникальномуИдентификатору();
	ДобавитьОписаниеВременнойТаблицы("&" + ИмяПараметра, Псевдоним);
	
	Если ТипИсточника = Тип("ТаблицаЗначений") Тогда
		Для Каждого Колонка Из Таблица.Колонки Цикл
			ДоступноеПоле(Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(ИмяПараметра, Таблица);
	ИначеЕсли ТипИсточника = Тип("ДанныеФормыКоллекция") Тогда
		Результат = Таблица.Выгрузить();
		Для Каждого Колонка Из Результат.Колонки Цикл
			Если Колонка.Имя = "ИсходныйНомерСтроки" Тогда
				Продолжить;
			КонецЕсли;
			ДоступноеПоле(Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(ИмяПараметра, Результат);
	ИначеЕсли СтрНайти(Таблица, "ТабличнаяЧасть.") > 0 Тогда
		Результат = Таблица.Выгрузить();
		Для Каждого Колонка Из Результат.Колонки Цикл
			ДоступноеПоле(Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(ИмяПараметра, Результат);
	ИначеЕсли ТипИсточника = Тип("Структура") Тогда
		ТаблицаИзJSON = РаботаСКоллекцией.СтруктураВТаблицуЗначений(Таблица);
		Для Каждого Колонка Из ТаблицаИзJSON.Колонки Цикл
			ДоступноеПоле(Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(ИмяПараметра, ТаблицаИзJSON);
	ИначеЕсли ТипИсточника = Тип("ТабличныйДокумент") Тогда
		ОбластьЯчеек = Таблица.Область(1, 1, Таблица.ВысотаТаблицы, Таблица.ШиринаТаблицы);
		Построитель = Новый ПостроительЗапроса;
		Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(ОбластьЯчеек);
		Построитель.ДобавлениеПредставлений = ТипДобавленияПредставлений.НеДобавлять;
		Построитель.ЗаполнитьНастройки();
		Построитель.Выполнить();
		Результат = Построитель.Результат.Выгрузить();
		Для Каждого Колонка Из Результат.Колонки Цикл
			ДоступноеПоле(Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(ИмяПараметра, Результат);
	Иначе
		ВызватьИсключение СтрШаблон("Неизвестный тип источника %1", ТипИсточника);
	КонецЕсли;
	
	Возврат ЭтотОбъект;
КонецФункции

Функция ВременнаяТаблица(Таблица, Знач Псевдоним = "", ЗначениеПараметра = Неопределено) Экспорт
	
	Если ОператорВыбрать = Неопределено Тогда
		Выбрать();
	КонецЕсли;

	ТипИсточника = ТипЗнч(Таблица);
	
	Если ТипИсточника = Тип("Строка") Тогда

		Если СтрНачинаетсяС(Таблица, "{") Тогда
			//  Это таблица JSON
			ТаблицаИзJSON = РаботаСКоллекцией.СтруктураВТаблицуЗначений(Таблица);
			Источник(ТаблицаИзJSON, Псевдоним);
			Возврат ЭтотОбъект;
			
		КонецЕсли;
		
		Если СтрНачинаетсяС(Таблица, "&") Тогда
			//  Это параметр
			ДобавитьОписаниеВременнойТаблицы(Таблица, Псевдоним);
			
			Если ЗначениеПараметра <> Неопределено Тогда
				ИмяПараметра = Прав(Таблица, СтрДлина(Таблица) - 1);
				Параметр(ИмяПараметра, ЗначениеПараметра);
			КонецЕсли;
			
			Возврат ЭтотОбъект;
			
		КонецЕсли;

		ДобавитьОписаниеВременнойТаблицы(Таблица, Псевдоним);
		ВременнаяТаблица = ?(МенеджерВременныхТаблиц <> Неопределено, МенеджерВременныхТаблиц.Таблицы.Найти(Таблица), Неопределено);
		
		Если ВременнаяТаблица <> Неопределено Тогда
			//  Это имя временной таблицы из менеджера временных таблиц
			Для Каждого Колонка Из ВременнаяТаблица.Колонки Цикл
				// при добавлении доступного поля нужен Тип, хотя в описании будет хранится ТипЗначения
				// ограничения: использование полей через точку только для 1-го типа, нельзя использовать оператор ССЫЛКА
				// 1-ой - использовать явные соединения с таблицами, 2-ое - использовать функцию ТипЗначения()
				ДоступноеПоле(Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
			КонецЦикла;
			
			Возврат ЭтотОбъект;
			
		КонецЕсли;
		
		Возврат ЭтотОбъект;
		
	КонецЕсли;
	
	//  Это Таблица значений, ТабличнаяЧасть, ДанныеФормыКоллекцияЗначений
	ИмяПараметра = ОбщийКлиентСервер.ИмяПоУникальномуИдентификатору();
	ДобавитьОписаниеВременнойТаблицы("&" + ИмяПараметра, Псевдоним);
	
	Если ТипИсточника = Тип("ТаблицаЗначений") Тогда
		Для Каждого Колонка Из Таблица.Колонки Цикл
			ДоступноеПоле(Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(ИмяПараметра, Таблица);
	ИначеЕсли ТипИсточника = Тип("ДанныеФормыКоллекция") Тогда
		Результат = Таблица.Выгрузить();
		Для Каждого Колонка Из Результат.Колонки Цикл
			Если Колонка.Имя = "ИсходныйНомерСтроки" Тогда
				Продолжить;
			КонецЕсли;
			ДоступноеПоле(Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(ИмяПараметра, Результат);
	ИначеЕсли СтрНайти(Таблица, "ТабличнаяЧасть.") > 0 Тогда
		Результат = Таблица.Выгрузить();
		Для Каждого Колонка Из Результат.Колонки Цикл
			ДоступноеПоле(Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(ИмяПараметра, Результат);
	ИначеЕсли ТипИсточника = Тип("Структура") Тогда
		ТаблицаИзJSON = РаботаСКоллекцией.СтруктураВТаблицуЗначений(Таблица);
		Для Каждого Колонка Из ТаблицаИзJSON.Колонки Цикл
			ДоступноеПоле(Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(ИмяПараметра, ТаблицаИзJSON);
	ИначеЕсли ТипИсточника = Тип("ТабличныйДокумент") Тогда
		ОбластьЯчеек = Таблица.Область(1, 1, Таблица.ВысотаТаблицы, Таблица.ШиринаТаблицы);
		Построитель = Новый ПостроительЗапроса;
		Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(ОбластьЯчеек);
		Построитель.ДобавлениеПредставлений = ТипДобавленияПредставлений.НеДобавлять;
		Построитель.ЗаполнитьНастройки();
		Построитель.Выполнить();
		Результат = Построитель.Результат.Выгрузить();
		Для Каждого Колонка Из Результат.Колонки Цикл
			ДоступноеПоле(Колонка.Имя, Колонка.ТипЗначения.Типы()[0]);
		КонецЦикла;
		Параметр(ИмяПараметра, Результат);
	Иначе
		ВызватьИсключение СтрШаблон("Неизвестный тип источника %1", ТипИсточника);
	КонецЕсли;
	
	Возврат ЭтотОбъект;
КонецФункции

Функция ЛевоеСоединение(ПсевдонимСлева, ПсевдонимСправа, Условие = Неопределено) Экспорт
	Соединение(ПсевдонимСлева, ПсевдонимСправа, Условие, ТипСоединенияСхемыЗапроса.ЛевоеВнешнее);
	Возврат ЭтотОбъект;
КонецФункции

Функция ПравоеСоединение(ПсевдонимСлева, ПсевдонимСправа, Условие = Неопределено) Экспорт
	Соединение(ПсевдонимСлева, ПсевдонимСправа, Условие, ТипСоединенияСхемыЗапроса.ПравоеВнешнее);
	Возврат ЭтотОбъект;
КонецФункции

