Функция ДоступноеПоле(Имя, Тип = Неопределено) Экспорт
	// Поскольку тип Строка нельзя ограничить (нет квалификатора строки как у типа значения),
	// то используется тип Неопределено.
	// Это нужно для того, чтобы не возникало фантомной ошибки
	// в условиях отбора и соединения: нельзя использовать поля неограниченной длины
	ДоступныеПоля.Добавить(Имя, ?(Тип = Тип("Строка"), Неопределено, Тип));
	Возврат ЭтотОбъект;
КонецФункции

// Добавить условие отбора в оператор выбора
// 
// Параметры:
//  Выражение - Строка, ВыраженияСхемыЗапроса - выражение отбора, соответствует выражению ГДЕ
// 
// Возвращаемое значение:
//  ОбработкаОбъект.МодельЗапроса
Функция Отбор(Выражение, Действует = Истина) Экспорт
	Если НЕ Действует Тогда
		Возврат ЭтотОбъект;
	КонецЕсли;
	ОператорВыбрать.Отбор.Добавить(Выражение);
	Возврат ЭтотОбъект;
КонецФункции

// Добавить условие отбора в оператор выбора
// 
// Параметры:
//  Выражение - Строка, ВыраженияСхемыЗапроса - выражение отбора, соответствует выражению ГДЕ
// 
// Возвращаемое значение:
//  ОбработкаОбъект.МодельЗапроса
Функция УсловныйОтбор(ЭтоИстина, ВыражениеИстина = Неопределено, ВыражениеЛожь = Неопределено) Экспорт
	Если ЭтоИстина Тогда
		Если НЕ ЗначениеЗаполнено(ВыражениеИстина) Тогда
			Возврат ЭтотОбъект;
		КонецЕсли;
		Отбор(ВыражениеИстина);
		Возврат ЭтотОбъект;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ВыражениеЛожь) Тогда
		Возврат ЭтотОбъект;
	КонецЕсли;
	Отбор(ВыражениеЛожь);
	Возврат ЭтотОбъект;
КонецФункции

