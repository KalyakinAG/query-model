// Оператор
// 
// Пример:
//	Оператор(Новый Структура("ТипОбъединения, КоличествоПолучаемыхЗаписей", ТипОбъединенияСхемыЗапроса.Объединить, 50));
//
// Параметры:
//   - см. НовыйМодельЗапроса
//  Параметры - Структура - Параметры:
//   * ВыбиратьРазличные - Булево
//	 * ТипОбъединения - ТипОбъединенияСхемыЗапроса - по умолчанию - ОбъединитьВсе
//	 * КоличествоПолучаемыхЗаписей - Число - по умолчанию - неограничено
Функция Выбрать(Количество = Неопределено, Различные = Неопределено, ТипОбъединения = Неопределено, ИндексКопии = Неопределено) Экспорт
	
	Если ИндексКопии <> Неопределено Тогда
		Если ТипЗнч(ИндексКопии) = Тип("Число") Тогда
			Если ИндексКопии < 0 Тогда
				ОператорИсточник = ЗапросПакета.Операторы[ЗапросПакета.Операторы.Количество() + ИндексКопии];
			Иначе
				ОператорИсточник = ЗапросПакета.Операторы[ИндексКопии];
			КонецЕсли;
		ИначеЕсли ТипЗнч(ИндексКопии) = Тип("ОператорВыбратьСхемыЗапроса") Тогда
			ОператорИсточник = ИндексКопии;
		Иначе
			ВызватьИсключение "Неизвестный тип оператора-источника: " + ТипЗнч(ИндексКопии);
		КонецЕсли;
		ОператорВыбрать = ЗапросПакета.Операторы.Добавить(ОператорИсточник);
	Иначе
		Если ЗапросПакета.Операторы.Количество() = 1 Тогда
			ОператорВыбрать = ЗапросПакета.Операторы[0];
			Если НЕ ОператорВыбрать.Источники.Количество() = 0 ИЛИ НЕ ОператорВыбрать.ВыбираемыеПоля.Количество() = 0 Тогда
				ОператорВыбрать = ЗапросПакета.Операторы.Добавить();
			КонецЕсли;
		Иначе
			ОператорВыбрать = ЗапросПакета.Операторы.Добавить();
		КонецЕсли; 
	КонецЕсли;
	
	Если Количество <> Неопределено Тогда
		ОператорВыбрать.КоличествоПолучаемыхЗаписей = Количество;
	КонецЕсли;
	
	Если Различные <> Неопределено Тогда
		ОператорВыбрать.ВыбиратьРазличные = Различные;
	КонецЕсли;
	
	ОператорВыбрать.ТипОбъединения = ?(ТипОбъединения = Неопределено, ТипОбъединенияСхемыЗапроса.ОбъединитьВсе, ТипОбъединения);
	ИндексОператора = ЗапросПакета.Операторы.Индекс(ОператорВыбрать);
	ВыбираемыеПоля	= ОператорВыбрать.ВыбираемыеПоля;
	
	Возврат ЭтотОбъект;
КонецФункции

Функция ВыбратьРазличные() Экспорт
	Выбрать(, Истина);
	Возврат ЭтотОбъект;
КонецФункции

Функция ВыбратьПервые(Количество = 1) Экспорт
	Выбрать(Количество);
	Возврат ЭтотОбъект;
