КонецФункции

// Добавить условие соединения
// 
// Параметры:
//  СоответствиеПолей - Строка - условие соединения описывается через перечисление соответствия полей: ПолеСлева = ПолеСправа[,..]
//                               Допускается указать справа параметр: ПолеСлева = &Параметр. Если поля имеют одинаковое имя слева и справа, то
//                               достаточно указать просто имя поля: Поле, ПолеСлева = ПолеСправа[,..]
// 
Функция Связь(СоответствиеПолей, Действует = Истина) Экспорт
	Перем ДоступныеПоля;
	
	Если СоответствиеПолей = "*" Тогда
		ОбщиеПоля = Новый Массив;
		ДоступныеПоля = ИсточникСправа.Источник.ДоступныеПоля;
		Для Каждого ПолеСлева Из ИсточникСлева.Источник.ДоступныеПоля Цикл
			Если ДоступныеПоля.Найти(ПолеСлева.Имя) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ОбщиеПоля.Добавить(ПолеСлева.Имя);
		КонецЦикла;
		Выражение = УсловиеСоединения(ОбщиеПоля);
	Иначе
		Выражение = УсловиеСоединения(СоответствиеПолей);
	КонецЕсли;
	
	УсловиеСвязи(Выражение, Действует);
	
	Возврат ЭтотОбъект;
КонецФункции

// Добавить условие соединения
// 
// Параметры:
//  Выражение - Строка - Выражение условия соединения
Функция УсловиеСвязи(Знач Выражение, Действует = Истина) Экспорт

	Если НЕ Действует Тогда
		Возврат ЭтотОбъект;
	КонецЕсли;
	
	ПсевдонимСлева = ИсточникСлева.Источник.Псевдоним;
	ПсевдонимСправа = ИсточникСправа.Источник.Псевдоним;
	Выражение = СтрЗаменить(Выражение, "%1", ПсевдонимСлева); 
	Выражение = СтрЗаменить(Выражение, "%2", ПсевдонимСправа);

	Если Соединение = Неопределено Тогда
		
		ИсточникСлева.Соединения.Добавить(ПсевдонимСправа, Выражение);
		Соединение = ИсточникСлева.Соединения[ИсточникСлева.Соединения.Количество()-1];
		Соединение.ТипСоединения = ТипСоединения;
		Возврат ЭтотОбъект; 

	КонецЕсли;
	
	ДобавитьУсловиеСоединения(Соединение, Выражение);		

	Возврат ЭтотОбъект;
КонецФункции

Функция ИсточникНачать(Псевдоним) Экспорт
