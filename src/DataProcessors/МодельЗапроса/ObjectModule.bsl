//		"ВТ_КЛЮЧЕВАЯ_СТАВКА"
//	)
Функция ПредставлениеСрезПоследнихПоДатам(Источник, ДатаНачала, ДатаОкончания, Условие = "", Знач ИсточникДаты = "", Знач Псевдоним = "") Экспорт
	
	Если ОператорВыбрать = Неопределено Тогда
		Выбрать();
	КонецЕсли;

	Если ПустаяСтрока(Псевдоним) Тогда
		Псевдоним = Псевдоним(Источник);
	КонецЕсли;
		
	ИндексЗапросаПакета = СхемаЗапроса.ПакетЗапросов.Индекс(ЗапросПакета);
	ЭлементИндекса = РаботаСМассивом.НайтиЭлемент(ИндексЗапроса, "Элемент.Значение = " + XMLСтрока(ИндексЗапросаПакета));
	
	Если ЭлементИндекса <> Неопределено Тогда
		ИмяЗапросаПакета = ЭлементИндекса.Ключ;
	Иначе
		ИмяЗапросаПакета = Неопределено;
	КонецЕсли;
	
	ТекущееСостояние = НовыйСостояние(ЭтотОбъект);

	Если ПустаяСтрока(ИсточникДаты) Тогда
		ИсточникДаты = ОбщийКлиентСервер.ИмяПоУникальномуИдентификатору();
		ЭтотОбъект.ЗапросПакета(, ИндексЗапросаПакета).Поместить(ИсточникДаты)
			.ПредставлениеСрезДат(ДатаНачала, ДатаОкончания)
		;
		ИндексЗапросаПакета = ИндексЗапросаПакета + 1;
	КонецЕсли;
	
	ВТ_ПЕРИОДЫ = Псевдоним + "_ПЕРИОДЫ";
	;//  ЗАПРОС ПАКЕТА. ВТ_ПЕРИОДЫ
	ЭтотОбъект.ЗапросПакета(, ИндексЗапросаПакета).Поместить(ВТ_ПЕРИОДЫ)
		.Источник(ИсточникДаты)
		.Источник(Источник, Псевдоним)
		.ВнутреннееСоединение(ИсточникДаты, Псевдоним)
			.УсловиеСвязи("%1.Дата >= %2.Период")
		.Отбор(СтрШаблон("Дата МЕЖДУ %1 И %2", ФорматДатаВремя(ДатаНачала), ФорматДатаВремя(ДатаОкончания)))
		.Отбор(Условие, ЗначениеЗаполнено(Условие))
		//  Дата->Период
		.Поле(ИсточникДаты + ".Дата")
		.Максимум(Псевдоним + ".Период")
	;//  ЗАПРОС ПАКЕТА.
	ИндексЗапросаПакета = ИндексЗапросаПакета + 1;
	// Сдвинуть индекс запроса
	Если ИмяЗапросаПакета <> Неопределено Тогда
		ИндексЗапроса.Вставить(ИмяЗапросаПакета, ИндексЗапросаПакета);
	КонецЕсли;
	// Восстановить текущее состояние
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ТекущееСостояние);
	// Добавить источник
	ЭтотОбъект
		.Источник(ВТ_ПЕРИОДЫ)
		.Источник(Источник, Псевдоним)
		.ВнутреннееСоединение(ВТ_ПЕРИОДЫ, Псевдоним)
			.Связь("Период")
		.Отбор(Условие, ЗначениеЗаполнено(Условие))
		//  Дата->Период
		.Поле(ВТ_ПЕРИОДЫ + ".Дата")
		.Поле(Псевдоним + ".Период")
		//  Ресурсы
		.Поле(Псевдоним + ".*")
	;
	Возврат ЭтотОбъект;
	
КонецФункции

//  ЗАПРОС ПАКЕТА. ВТ_ДЕНЕЖНЫЕ_СРЕДСТВА_ЭСКРОУ
//	.ПредставлениеОборотыИОстаткиПоДатам( 
//		"ВТ_ДАТЫ", 
//		"РегистрНакопления.ДенежныеСредстваЭскроу.ОстаткиИОбороты", 
//		,
//		"Сумма", 
//		"Организация = &Организация И Банк = &Банк", 
//		"&ДатаНачала", 
//		"&ДатаОкончания", 
//		"ВТ_ДЕНЕЖНЫЕ_СРЕДСТВА_ЭСКРОУ"
//	)
Функция ПредставлениеОборотыИОстаткиПоДатам(Источник, ДатаНачала = "&ДатаНачала", ДатаОкончания = "&ДатаОкончания", Измерения = "", Ресурс = "Сумма", Условие = "", ИсточникДаты = "", Псевдоним = "") Экспорт
	
	Если ОператорВыбрать = Неопределено Тогда
		Выбрать();
	КонецЕсли;

	Если ПустаяСтрока(Псевдоним) Тогда
		Псевдоним = Псевдоним(Источник);
	КонецЕсли;
		
	ИндексЗапросаПакета = СхемаЗапроса.ПакетЗапросов.Индекс(ЗапросПакета);
	ЭлементИндекса = РаботаСМассивом.НайтиЭлемент(ИндексЗапроса, "Элемент.Значение = " + XMLСтрока(ИндексЗапросаПакета));
	
	Если ЭлементИндекса <> Неопределено Тогда
		ИмяЗапросаПакета = ЭлементИндекса.Ключ;
	Иначе
		ИмяЗапросаПакета = Неопределено;
	КонецЕсли;
	
	ТекущееСостояние = НовыйСостояние(ЭтотОбъект);

	Если ПустаяСтрока(ИсточникДаты) Тогда
		ИсточникДаты = ОбщийКлиентСервер.ИмяПоУникальномуИдентификатору();
		ЭтотОбъект.ЗапросПакета(, ИндексЗапросаПакета).Поместить(ИсточникДаты)
			.ПредставлениеСрезДат(ДатаНачала, ДатаОкончания)
		;
		ИндексЗапросаПакета = ИндексЗапросаПакета + 1;
	КонецЕсли;
	
	МодельЗапроса = ЭтотОбъект;
	ВТ_ОСТАТКИ_И_ОБОРОТЫ = Псевдоним + "_ОСТАТКИ_И_ОБОРОТЫ";
	ВТ_ПЕРИОДЫ = Псевдоним + "_ПЕРИОДЫ";
	;//  ЗАПРОС ПАКЕТА. ВТ_ОСТАТКИ_И_ОБОРОТЫ
	МодельЗапроса.ЗапросПакета(, ИндексЗапросаПакета).Поместить(ВТ_ОСТАТКИ_И_ОБОРОТЫ)
		.Источник(Источник)
			.ДвиженияИГраницыПериода()
			.НачалоПериода(ДатаНачала)
			.КонецПериода(ДатаОкончания)
			.ПериодичностьДень()
			.Условие(Условие, ЗначениеЗаполнено(Условие))
		//  Период
		.Поле("Период")
		;//  Измерения
		Если ЗначениеЗаполнено(Измерения) Тогда
			Для Каждого Измерение Из ОбщийКлиентСервер.Массив(Измерения) Цикл
				МодельЗапроса.Поле(Измерение);
			КонецЦикла;
		КонецЕсли;
		МодельЗапроса
		//  Ресурсы
		.Поле(Ресурс + "НачальныйОстаток")
		.Поле(Ресурс + "Приход")
		.Поле(Ресурс + "Расход")
		.Поле(Ресурс + "КонечныйОстаток")
	;//  ЗАПРОС ПАКЕТА. ВТ_ПЕРИОДЫ
	ИндексЗапросаПакета = ИндексЗапросаПакета + 1;
	МодельЗапроса.ЗапросПакета(, ИндексЗапросаПакета).Поместить(ВТ_ПЕРИОДЫ)
		.Источник(ИсточникДаты)
		.Источник(ВТ_ОСТАТКИ_И_ОБОРОТЫ)
		.ВнутреннееСоединение(ИсточникДаты, ВТ_ОСТАТКИ_И_ОБОРОТЫ)
			.УсловиеСвязи("%1.Дата >= %2.Период")
		//  Дата->Период
		.Поле(ИсточникДаты + ".Дата")
		;//  Измерения
		Если ЗначениеЗаполнено(Измерения) Тогда
			Для Каждого Измерение Из ОбщийКлиентСервер.Массив(Измерения) Цикл
				МодельЗапроса.Поле(Измерение);
			КонецЦикла;
		КонецЕсли;
		МодельЗапроса
			.Максимум(ВТ_ОСТАТКИ_И_ОБОРОТЫ + ".Период")
	;//  ЗАПРОС ПАКЕТА.
	ИндексЗапросаПакета = ИндексЗапросаПакета + 1;
	// Сдвинуть индекс запроса
	Если ИмяЗапросаПакета <> Неопределено Тогда
		ИндексЗапроса.Вставить(ИмяЗапросаПакета, ИндексЗапросаПакета);
	КонецЕсли;
	// Восстановить текущее состояние
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ТекущееСостояние);
	// Добавить источник
	МодельЗапроса
		.Источник(ВТ_ПЕРИОДЫ)
		.Источник(ВТ_ОСТАТКИ_И_ОБОРОТЫ)
		.ВнутреннееСоединение(ВТ_ПЕРИОДЫ, ВТ_ОСТАТКИ_И_ОБОРОТЫ)
			.Связь("Период")
		;
		Если ЗначениеЗаполнено(Измерения) Тогда
			МодельЗапроса.Связь(Измерения);
		КонецЕсли;
		МодельЗапроса
			//  Дата->Период
			.Поле(ВТ_ПЕРИОДЫ + ".Дата")
			.Поле(ВТ_ОСТАТКИ_И_ОБОРОТЫ + ".Период")
			;//  Измерения
			Если ЗначениеЗаполнено(Измерения) Тогда
				МодельЗапроса.Поле(РаботаСМассивом.Отобразить(ОбщийКлиентСервер.Массив(Измерения), СтрШаблон("'%1.' + Элемент", ВТ_ОСТАТКИ_И_ОБОРОТЫ)));
			КонецЕсли;
			МодельЗапроса
			//  Ресурсы
			.Поле(СтрШаблон("ВЫБОР
				|	КОГДА %1.Дата = %2.Период
				|		ТОГДА %2.%3НачальныйОстаток
				|	ИНАЧЕ %2.%3КонечныйОстаток
				|КОНЕЦ", ВТ_ПЕРИОДЫ, ВТ_ОСТАТКИ_И_ОБОРОТЫ, Ресурс), Ресурс + "НачальныйОстаток")
			.Поле(СтрШаблон("ВЫБОР
				|	КОГДА %1.Дата = %2.Период
				|		ТОГДА %2.%3Приход
				|	ИНАЧЕ 0
				|КОНЕЦ", ВТ_ПЕРИОДЫ, ВТ_ОСТАТКИ_И_ОБОРОТЫ, Ресурс), Ресурс + "Приход")
			.Поле(СтрШаблон("ВЫБОР
				|	КОГДА %1.Дата = %2.Период
				|		ТОГДА %2.%3Расход
				|	ИНАЧЕ 0
				|КОНЕЦ", ВТ_ПЕРИОДЫ, ВТ_ОСТАТКИ_И_ОБОРОТЫ, Ресурс), Ресурс + "Расход")
			.Поле(СтрШаблон("%1.%2КонечныйОстаток", ВТ_ОСТАТКИ_И_ОБОРОТЫ, Ресурс))
	;
	Возврат ЭтотОбъект;
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

//  Возвращаемое значение: КолонкиВременнойТаблицыЗапроса(Имя, ТипЗначения) | ДоступноеПолеСхемыЗапроса(Имя, ТипЗначения)
Функция ДоступныеПоля(ИмяТаблицы)
	ВременныеТаблицы = ЗапросПакета.ДоступныеТаблицы.Найти("Временные таблицы");
	Если ВременныеТаблицы <> Неопределено Тогда
		ИсточникТаблицы = ВременныеТаблицы.Состав.Найти(ИмяТаблицы);
		Если ИсточникТаблицы <> Неопределено Тогда
			Возврат ИсточникТаблицы.Поля;
		КонецЕсли;
	КонецЕсли;
	ИсточникТаблицы = МенеджерВременныхТаблиц.Таблицы.Найти(ИмяТаблицы);
	Если ИсточникТаблицы <> Неопределено Тогда
		Возврат ИсточникТаблицы.Колонки;
	КонецЕсли;
	Возврат Новый Массив;
КонецФункции

Функция ПоляТаблицы(ИмяТаблицы, ПоляИсточника = Неопределено)
	Поля = Новый Массив;
	Если ПоляИсточника = Неопределено Тогда
		Для Каждого ДоступноеПоле Из ДоступныеПоля(ИмяТаблицы) Цикл
			Поля.Добавить(ДоступноеПоле.Имя);
		КонецЦикла;
		Возврат Поля;
	КонецЕсли;
	Для Каждого ДоступноеПоле Из ДоступныеПоля(ИмяТаблицы) Цикл
		Если ПоляИсточника.Найти(ДоступноеПоле.Имя) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Поля.Добавить(ДоступноеПоле.Имя);
	КонецЦикла;
	Возврат Поля;
КонецФункции

// Формирует текст выражения вхождения по шаблону:
// (<Поля слева>) В (ВЫБРАТЬ <Поля справа> ИЗ <Имя таблицы> КАК <Имя таблицы>)
// 
// Параметры:
//  ИмяТаблицы - Строка - Имя таблицы
//  Поля - Строка - Поля или соответствия полей слева и справа
//                 <Поле слева> = <Поле справа>|<Поле>|<Поле слева> = &<Параметр справа>[, ...]
//  ПоляИсточника - Строка, Неопределено - Поля источника
// 
// Возвращаемое значение:
//  Строка - Выражение вхождения
Функция ВыражениеВхождения(ИмяТаблицы, Поля = "*", ПоляИсточника = Неопределено)
	Если Поля = "*" Тогда
		Поля = ПоляТаблицы(ИмяТаблицы, ПоляИсточника);
		ПоляСлева = Поля; 
		ПоляСправа = Поля;
		Возврат СтрШаблон("(%1) В (ВЫБРАТЬ РАЗЛИЧНЫЕ %2 ИЗ %3 КАК %3)", СтрСоединить(Поля, ", "), ИмяТаблицы + "." + СтрСоединить(Поля, ", " + ИмяТаблицы + "."), ИмяТаблицы);
	КонецЕсли;
	ПоляСлева = Новый Массив;
	ПоляСправа = Новый Массив;
	Для Каждого Связь Из ОбщийКлиентСервер.Массив(Поля) Цикл
		Состав = СтрРазделить(Связь, "=", Ложь);
		Если Состав.Количество() = 1 Тогда
			ПоляСлева.Добавить(Связь);
			ПоляСправа.Добавить(ИмяТаблицы + "." +Связь);
			Продолжить;
		КонецЕсли;
		ПоляСлева.Добавить(Состав[0]);
		ПолеСправа = Состав[1];
		Если СтрНачинаетсяС(ПолеСправа, "&") Тогда
			ПоляСправа.Добавить(Состав[1]);
			Продолжить;
		КонецЕсли;
		ПоляСправа.Добавить(ИмяТаблицы + "." + ПолеСправа);
	КонецЦикла;
	Возврат СтрШаблон("(%1) В (ВЫБРАТЬ РАЗЛИЧНЫЕ %2 ИЗ %3 КАК %3)", СтрСоединить(ПоляСлева, ", "), СтрСоединить(ПоляСправа, ", "), ИмяТаблицы);
КонецФункции

Функция Псевдоним(Выражение, Псевдоним = "")
	Если НЕ ПустаяСтрока(Псевдоним) Тогда
		Возврат Псевдоним;
	КонецЕсли;
	Если Лев(Выражение, 1) = "&" Тогда
		Возврат Прав(Выражение, СтрДлина(Выражение) - 1);
	КонецЕсли;
	Позиция = СтрНайти(Выражение, ".", НаправлениеПоиска.СНачала);
	Если Позиция > 0 Тогда
		ПсевдонимПоля = Прав(Выражение, СтрДлина(Выражение) - Позиция);
	Иначе
		ПсевдонимПоля = Выражение;
	КонецЕсли;
	Возврат СтрЗаменить(ПсевдонимПоля, ".", "");
КонецФункции

// Добавляет выбранное поле компоновки данных
//
// Параметры:
//	Куда		(КомпоновщикНастроекКомпоновкиДанных, НастройкиКомпоновкиДанных, ВыбранныеПоляКомпоновкиДанных)
//	ИмяИлиПолеКД(Строка, ПолеКомпоновкиДанных)
//	Заголовок	(Строка) Необязательный
//
// Возвращаемое значение:
//	ВыбранноеПолеКД (ВыбранноеПолеКомпоновкиДанных)
//
Функция ДобавитьВыбранноеПолеСКД(Куда, ИмяИлиПолеКД, Заголовок = "")
	
	Если ТипЗнч(Куда) = Тип("КомпоновщикНастроекКомпоновкиДанных") Тогда
		ВыбранныеПоляКД = Куда.Настройки.Выбор;
	ИначеЕсли ТипЗнч(Куда) = Тип("НастройкиКомпоновкиДанных") Тогда
		ВыбранныеПоляКД = Куда.Выбор;
	Иначе
		ВыбранныеПоляКД = Куда;
	КонецЕсли;
	
	Если ТипЗнч(ИмяИлиПолеКД) = Тип("Строка") Тогда
		ПолеКД = Новый ПолеКомпоновкиДанных(ИмяИлиПолеКД);
	Иначе
		ПолеКД = ИмяИлиПолеКД;
	КонецЕсли;
	
	ВыбранноеПолеКД = ВыбранныеПоляКД.Элементы.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
	ВыбранноеПолеКД.Поле = ПолеКД;
	Если Заголовок <> "" Тогда
		ВыбранноеПолеКД.Заголовок = Заголовок;
	КонецЕсли;
	
	Возврат ВыбранноеПолеКД;
	
КонецФункции

// Добавляет отбор в коллекцию отборов компоновщика или группы отборов
//
// Параметры:
//	ЭлементСтруктуры- элемент структуры КД
//	Поле			- имя поля, по которому добавляется отбор
//	Значение		- значение отбора КД
//	ВидСравнения	- вид сравнений КД (по умолчанию: неопределено)
//	Использование	- признак использования отбора (по умолчанию: истина)
//	ВПользовательскиеНастройки - признак добавления в пользовательсие настройки КД (по умолчанию: ложь)
//
// Возвращаемое значение:
//	ЭлементОтбора (ЭлементОтбораКомпоновкиДанных)
//
Функция ДобавитьОтборСКД(ЭлементСтруктуры, Знач Поле, Значение, ВидСравнения = Неопределено, Использование = Истина, ВПользовательскиеНастройки = Ложь)
	
	Если ТипЗнч(Поле) = Тип("Строка") Тогда
		Поле = Новый ПолеКомпоновкиДанных(Поле);
	КонецЕсли;
	
	Если ТипЗнч(ЭлементСтруктуры) = Тип("КомпоновщикНастроекКомпоновкиДанных") Тогда
		Отбор = ЭлементСтруктуры.Настройки.Отбор;
		
		Если ВПользовательскиеНастройки Тогда
			Для Каждого ЭлементНастройки Из ЭлементСтруктуры.ПользовательскиеНастройки.Элементы Цикл
				Если ЭлементНастройки.ИдентификаторПользовательскойНастройки = ЭлементСтруктуры.Настройки.Отбор.ИдентификаторПользовательскойНастройки Тогда
					Отбор = ЭлементНастройки;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ЭлементСтруктуры) = Тип("НастройкиКомпоновкиДанных") Тогда
		Отбор = ЭлементСтруктуры.Отбор;
	Иначе
		Отбор = ЭлементСтруктуры;
	КонецЕсли;
	
	Если ВидСравнения = Неопределено Тогда
		ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	КонецЕсли;
	
	ЭлементОтбора = Неопределено;
	Для каждого Элемент Из Отбор.Элементы Цикл
		
		Если ТипЗнч(Элемент) = Тип("ГруппаЭлементовОтбораКомпоновкиДанных") Тогда
			Продолжить;
		КонецЕсли;
		
		Если Элемент.ЛевоеЗначение = Поле Тогда
			ЭлементОтбора = Элемент;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЭлементОтбора = Неопределено Тогда
		ЭлементОтбора = Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	КонецЕсли;
	
	ЭлементОтбора.Использование		= Использование;
	ЭлементОтбора.ЛевоеЗначение		= Поле;
	ЭлементОтбора.ВидСравнения		= ВидСравнения;
	ЭлементОтбора.ПравоеЗначение	= Значение;
	
	Возврат ЭлементОтбора;
	
КонецФункции

Функция ПолучитьИсточник(ИндексИлиПсевдоним = Неопределено)
	Перем Источник;
	Если ТипЗнч(ИндексИлиПсевдоним) = Тип("Строка") Тогда
		Источник = ОператорВыбрать.Источники.НайтиПоПсевдониму(ИндексИлиПсевдоним);
		Если Источник = Неопределено Тогда
			Источник = ОператорВыбрать.Источники.НайтиПоИмени(ИндексИлиПсевдоним);
		КонецЕсли;
		Возврат Источник;
	КонецЕсли;
	Если ИндексИлиПсевдоним = Неопределено Тогда
		ВыбранныйИндекс = ОператорВыбрать.Источники.Количество() - 1;
	Иначе
		ВыбранныйИндекс = ИндексИлиПсевдоним;
	КонецЕсли;
	Если ВыбранныйИндекс = -1 Тогда
		Источник = Неопределено;
		Возврат Источник;
	КонецЕсли;
	Источник = ОператорВыбрать.Источники[ВыбранныйИндекс];
	Возврат Источник;
КонецФункции

Процедура ДополнитьВыражениеПараметра(Источник, ИмяПараметра, Выражение)
	Перем ТекущееВыражение;
	ПараметрыТаблицы = ПараметрыВиртуальнойТаблицы(Источник.Источник.ИмяТаблицы, Источник.Источник.Параметры);
	Если ПараметрыТаблицы <> Неопределено И ПараметрыТаблицы.Свойство(ИмяПараметра, ТекущееВыражение) Тогда
		УстановитьПараметрыВиртуальнойТаблицы(Источник, Новый Структура(ИмяПараметра, СтрШаблон("(%1) И (%2)", ТекущееВыражение, Выражение)));
	Иначе
		УстановитьПараметрыВиртуальнойТаблицы(Источник, Новый Структура(ИмяПараметра, Выражение));
	КонецЕсли;
КонецПроцедуры

Функция ВыражениеВВидСубконто(Выражение)
	Если ТипЗнч(Выражение) <> Тип("Строка") Тогда
		Возврат Выражение;
	КонецЕсли;
	Состав = СтрРазделить(СтрЗаменить(Выражение, ")", ""), ".");
	Состав[0] = "ПланыВидовХарактеристик";
	Состав[2] = СтрЗаменить(Состав[2], ")", "");
	//@skip-check server-execution-safe-mode
	ЗначениеВыражения = Вычислить(СтрСоединить(Состав, "."));
	Возврат ЗначениеВыражения;
КонецФункции

Функция ВидСубконтоВВыражение(Выражение)
	Если ТипЗнч(Выражение) = Тип("Строка") Тогда
		Возврат Выражение;
	КонецЕсли;
	ЗначениеВыражения = СтрШаблон("ЗНАЧЕНИЕ(ПланВидовХарактеристик.%1.%2)", Выражение.Метаданные().Имя, Выражение.ИмяПредопределенныхДанных);
	Возврат ЗначениеВыражения;
КонецФункции

Процедура ДополнитьСубконто(Источник, Параметры, ПараметрТаблицы, Значение)
	Перем Выражение;
	ПараметрыТаблицы = ПараметрыВиртуальнойТаблицы(Источник.Источник.ИмяТаблицы, Источник.Источник.Параметры);
	Если ПараметрыТаблицы <> Неопределено И ПараметрыТаблицы.Свойство(ПараметрТаблицы, Выражение) И ЗначениеЗаполнено(Выражение) Тогда
		Если СтрНачинаетсяС(Выражение, "&") Тогда
			ИмяПараметра = Прав(Выражение, СтрДлина(Выражение) - 1);
			ЗначениеПараметра = Параметры[ИмяПараметра];
			Если ТипЗнч(ЗначениеПараметра) = Тип("Массив") Тогда
				ВидыСубконто = ЗначениеПараметра;
			Иначе
				ВидыСубконто = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ЗначениеПараметра);
			КонецЕсли;
			Если ТипЗнч(Значение) = Тип("Массив") Тогда
				ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ВидыСубконто, Значение);
			Иначе
				ВидыСубконто.Добавить(Значение);
			КонецЕсли;
			Параметры[ИмяПараметра] = ВидыСубконто;
			Возврат;
		КонецЕсли;
		ВидыСубконто = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ВыражениеВВидСубконто(Выражение));
		ВидыСубконто.Добавить(ВыражениеВВидСубконто(Значение));
		ИмяПараметра = ОбщийКлиентСервер.ИмяПоУникальномуИдентификатору();
		УстановитьПараметрыВиртуальнойТаблицы(Источник, Новый Структура(ПараметрТаблицы, "&" + ИмяПараметра));
		Параметры.Вставить(ИмяПараметра, ВидыСубконто);
	Иначе
		УстановитьПараметрыВиртуальнойТаблицы(Источник, Новый Структура(ПараметрТаблицы, ВидСубконтоВВыражение(Значение)));
	КонецЕсли;
КонецПроцедуры

Процедура ОчиститьСоединенияИсточника(Источник)
	
	Псевдоним = Источник.Источник.Псевдоним;
	Источник.Соединения.Очистить();
	
	Для Каждого ИсточникСоединения Из ОператорВыбрать.Источники Цикл
		Соединения = ИсточникСоединения.Соединения;
		СоединениеСИсточником = Соединения.НайтиПоПсевдониму(Псевдоним);
		Пока СоединениеСИсточником <> Неопределено Цикл
			Соединения.Удалить(Соединения.Индекс(СоединениеСИсточником));
			СоединениеСИсточником = Соединения.НайтиПоПсевдониму(Псевдоним);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьИсточник(Таблица, Псевдоним = "")

	Попытка
		ОператорВыбрать.Источники.Добавить(Таблица, Псевдоним);
	Исключение
		// возможно это временная таблица
		ДобавитьОписаниеВременнойТаблицы(Таблица, Псевдоним);
		Возврат;
	КонецПопытки;
	
	Источник = ОператорВыбрать.Источники[ОператорВыбрать.Источники.Количество()-1];
	ИсточникСлева = Источник;
	ДоступныеПоля = Источник.Источник.ДоступныеПоля;
	ОчиститьСоединенияИсточника(Источник);

КонецПроцедуры

Процедура ДобавитьВложенныйЗапрос(Псевдоним = "ВложенныйЗапрос")

	ОператорВыбрать.Источники.Добавить(Тип("ВложенныйЗапросСхемыЗапроса"), Псевдоним);
	Источник = ОператорВыбрать.Источники[ОператорВыбрать.Источники.Количество()-1];
	ИсточникСлева = Источник;
	ДоступныеПоля = Источник.Источник.ДоступныеПоля;
	ОчиститьСоединенияИсточника(Источник);

КонецПроцедуры

Процедура ДобавитьОписаниеВременнойТаблицы(Таблица, Псевдоним = "")

	ОператорВыбрать.Источники.Добавить(Тип("ОписаниеВременнойТаблицыСхемыЗапроса"), Таблица, Псевдоним);
	Источник = ОператорВыбрать.Источники[ОператорВыбрать.Источники.Количество()-1];
	ИсточникСлева = Источник;
	ДоступныеПоля = Источник.Источник.ДоступныеПоля;
	ОчиститьСоединенияИсточника(Источник);

КонецПроцедуры


Функция НовыйСостояние(МодельЗапроса = Неопределено)
	
	Состояние = Новый Структура;
	Состояние.Вставить("ЗапросПакета");
	Состояние.Вставить("ОператорВыбрать");
	Состояние.Вставить("Источник");
	Состояние.Вставить("ИсточникСлева");
	Состояние.Вставить("ИсточникСправа");
	Состояние.Вставить("Поле");
	Состояние.Вставить("Соединение");
	Состояние.Вставить("ТипСоединения");
	Состояние.Вставить("КонтрольнаяТочка");
	
	Состояние.Вставить("ИндексОператора");
	Состояние.Вставить("ВыбираемыеПоля");
	Состояние.Вставить("Колонки");
	
	Если МодельЗапроса = Неопределено Тогда
		Возврат Состояние;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Состояние, МодельЗапроса);
	Возврат Состояние;
	
КонецФункции

Процедура СохранитьСостояние()
	Стек.Добавить(НовыйСостояние(ЭтотОбъект));
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, НовыйСостояние());	
КонецПроцедуры

Процедура ВосстановитьСостояние()
	Стек = Стек;
	Состояние = Стек[Стек.ВГраница()];
	Стек.Удалить(Стек.ВГраница());
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Состояние);
КонецПроцедуры

// Установить параметры виртуальной таблицы.
// 
// Параметры:
//  Источник - ИсточникСхемыЗапроса - Источник
//	ПараметрыВиртуальнойТаблицы - Массив из Строка - параметры определяются индексом элемента массива. В качестве значения параметров выступает текстовое описание (см. встроенная справка - работа с запросом - таблицы - параметры).
//								- Структура - ключи структуры соответствуют названиям параметров виртуальной таблицы из справки в конфигураторе без пробелов. 
Процедура УстановитьПараметрыВиртуальнойТаблицы(Источник, ПараметрыВиртуальнойТаблицы)
	ПараметрыИсточника	= Источник.Источник.Параметры;
	ТипЗначения = ТипЗнч(ПараметрыВиртуальнойТаблицы);
	Если ТипЗначения = Тип("Структура") Тогда 
		СтруктураПараметров = ПараметрыВиртуальнойТаблицы(ИмяВиртуальнойТаблицы(Источник.Источник.ИмяТаблицы));
		Для каждого ЭлементПараметров Из ПараметрыВиртуальнойТаблицы Цикл
			Если ЭлементПараметров.Значение = "*" Тогда
				ПараметрыИсточника[СтруктураПараметров[ЭлементПараметров.Ключ]].Выражение = Новый ВыражениеСхемыЗапроса("&"+ЭлементПараметров.Ключ);
			Иначе
				ПараметрыИсточника[СтруктураПараметров[ЭлементПараметров.Ключ]].Выражение = Новый ВыражениеСхемыЗапроса(ЭлементПараметров.Значение);
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли ТипЗначения = Тип("ПараметрыТаблицыСхемыЗапроса") Тогда
		Индекс = -1;
		Для каждого Параметр Из ПараметрыВиртуальнойТаблицы Цикл
			Индекс = Индекс + 1;
			ПараметрыИсточника[Индекс].Выражение = Параметр.Выражение;
		КонецЦикла;
	Иначе //  массив
		Для Индекс = 0 По ПараметрыВиртуальнойТаблицы.ВГраница() Цикл
			ПараметрыИсточника[Индекс].Выражение = Новый ВыражениеСхемыЗапроса(ПараметрыВиртуальнойТаблицы[Индекс]);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Функция ИмяВиртуальнойТаблицы(ИмяТаблицы)
	МассивСлов = СтрРазделить(ИмяТаблицы, ".");
	Возврат МассивСлов[0]+"."+МассивСлов[2];
КонецФункции

Функция ИсточникПоПсевдониму(ОператорВыбрать, Псевдоним)
	
	Источник = ОператорВыбрать.Источники.НайтиПоПсевдониму(Псевдоним);
	
	Если Источник = Неопределено Тогда
		Источник = ОператорВыбрать.Источники.НайтиПоИмени(Псевдоним);
	КонецЕсли;
	
	Если Источник = Неопределено Тогда
		ВызватьИсключение СтрШаблон("Не удалось определить источник по псевдониму ""%1""", Псевдоним);
	КонецЕсли;
	
	Возврат Источник;
	
КонецФункции

Процедура Соединение(ПсевдонимСлева, ПсевдонимСправа, Условие = Неопределено, Тип = Неопределено)

	ТипСоединения = ?(Тип = Неопределено, ТипСоединенияСхемыЗапроса.ЛевоеВнешнее, Тип);
	ИсточникСлева = ИсточникПоПсевдониму(ОператорВыбрать, ПсевдонимСлева);
	ИсточникСправа = ИсточникПоПсевдониму(ОператорВыбрать, ПсевдонимСправа);
	Соединение = Неопределено;// само соединение будет добавлено в момент появления условия связи
	
	Если ЗначениеЗаполнено(Условие) Тогда
		УсловиеСвязи(Условие);
	КонецЕсли;
	
КонецПроцедуры

// Добавляет условие к существующим условиям соединения источников.
//
// Параметры:
//  Соединение - СоединениеИсточникаЗапросаСхемыЗапроса
//  Условие - Строка - псевдоним источника
Процедура ДобавитьУсловиеСоединения(Соединение, Условие)
	
	ТекущееУсловие = Строка(Соединение.Условие);
	
	Если ПустаяСтрока(ТекущееУсловие) Тогда
		Соединение.Условие = Новый ВыражениеСхемыЗапроса(Условие);
		Возврат;
	КонецЕсли;
	
	Соединение.Условие = Новый ВыражениеСхемыЗапроса(СтрШаблон("(%1) И (%2)", ТекущееУсловие, Условие));
	
КонецПроцедуры

Функция УсловиеСоединения(Поля)
	МассивУсловий = Новый Массив;
	Если ТипЗнч(Поля) = Тип("Строка") ИЛИ ТипЗнч(Поля) = Тип("Массив") Тогда
		Для каждого Поле Из ОбщийКлиентСервер.Массив(Поля) Цикл
			СоставПолей = СтрРазделить(Поле, "= ", Ложь);
			Если СоставПолей.ВГраница() = 0 Тогда
				ПолеСлева = СоставПолей[0];
				ПолеСправа = СоставПолей[0];
			Иначе
				ПолеСлева = СоставПолей[0];
				ПолеСправа = СоставПолей[1];
			КонецЕсли;
			МассивУсловий.Добавить(СтрШаблон("%%1.%1 = %%2.%2", ПолеСлева, ПолеСправа));
		КонецЦикла; 
	Иначе
		Для каждого Поле Из Поля Цикл
			МассивУсловий.Добавить(СтрШаблон("%%1.%1 = %%2.%1", Поле.Имя));
		КонецЦикла; 
	КонецЕсли; 
	Возврат СтрСоединить(МассивУсловий, " И ");	
КонецФункции

Функция ФорматДатаВремя(Значение)
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		Возврат Значение;
	КонецЕсли;
	Возврат СтрШаблон("ДАТАВРЕМЯ(%1)", Формат(Значение, "ДФ='yyyy, M, d, H, m, s';"));
КонецФункции

