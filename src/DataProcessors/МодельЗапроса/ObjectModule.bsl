// Группировка для итогов
// 
// Параметры:
//  Выражение - Строка - Выражение
//  ИмяКолонки - Строка - Имя колонки
//  ТипКонтрольнойТочки - ТипКонтрольнойТочкиСхемыЗапроса, Неопределено - Тип контрольной точки
//                        Иерархия, ТолькоИерархия, Элементы
// Возвращаемое значение:
//  ОбработкаОбъект.МодельЗапроса
Функция Группировка(Выражение, ИмяКолонки = "", ТипКонтрольнойТочки = Неопределено, ТипДополненияПериодами = Неопределено, НачалоПериода = "", КонецПериода = "") Экспорт
	КонтрольнаяТочка = ЗапросПакета.КонтрольныеТочкиИтогов.Добавить(Выражение);
	КонтрольнаяТочка.ИмяКолонки					= ИмяКолонки;
	КонтрольнаяТочка.ТипКонтрольнойТочки 		= ?(ТипКонтрольнойТочки 	= Неопределено, ТипКонтрольнойТочкиСхемыЗапроса.Элементы, ТипКонтрольнойТочки);
	КонтрольнаяТочка.ТипДополненияПериодами 	= ?(ТипДополненияПериодами 	= Неопределено, ТипДополненияПериодамиСхемыЗапроса.БезДополнения, ТипДополненияПериодами);
	КонтрольнаяТочка.НачалоПериодаДополнения 	= ?(ТипЗнч(НачалоПериода) 	= Тип("Строка"), НачалоПериода, ФорматДатаВремя(НачалоПериода));
	КонтрольнаяТочка.КонецПериодаДополнения 	= ?(ТипЗнч(КонецПериода) 	= Тип("Строка"), КонецПериода, ФорматДатаВремя(КонецПериода));
	Возврат ЭтотОбъект;
КонецФункции

// Группировки для итогов
// 
// Параметры:
//  Выражения - Массив из Строка - Выражения группировок итогов в формате "Выражение КАК Псевдоним", "Выражение"
// 
// Возвращаемое значение:
//  ОбработкаОбъект.МодельЗапроса
Функция Группировки(Выражения) Экспорт
	МассивВыражений = ?(ТипЗнч(Выражения) = Тип("Массив"), Выражения, СтрРазделить(Выражения, ","));
	Для Каждого ВыражениеПоля Из МассивВыражений Цикл
		ПозицияТокена = СтрНайти(ВРег(ВыражениеПоля), " КАК ");
		Если ПозицияТокена = 0 Тогда
			Псевдоним = "";
			Выражение = ВыражениеПоля;
		Иначе
			Выражение = Лев(ВыражениеПоля, ПозицияТокена - 1);
			Псевдоним = Прав(ВыражениеПоля, СтрДлина(ВыражениеПоля) - ПозицияТокена - 4);
		КонецЕсли;			
		Группировка(Выражение, Псевдоним);
	КонецЦикла;
	Возврат ЭтотОбъект;
КонецФункции

Функция Итоги(Выражения) Экспорт
	МассивВыражений = ?(ТипЗнч(Выражения) = Тип("Массив"), Выражения, СтрРазделить(Выражения, ","));
	Для Каждого ВыражениеПоля Из МассивВыражений Цикл
		ПозицияТокена = СтрНайти(ВРег(ВыражениеПоля), " КАК ");
		Если ПозицияТокена = 0 Тогда
			Псевдоним = "";
			Выражение = ВыражениеПоля;
		Иначе
			Выражение = Лев(ВыражениеПоля, ПозицияТокена - 1);
			Псевдоним = Прав(ВыражениеПоля, СтрДлина(ВыражениеПоля) - ПозицияТокена - 4);
		КонецЕсли;			
		Итог(Выражение, Псевдоним);
	КонецЦикла;
	Возврат ЭтотОбъект;
КонецФункции

// Дополнение результата запроса датами в установленном периоде
// https://its.1c.ru/db/metod8dev/content/2660/hdoc
Функция ПоПериодам(ТипДополненияПериодами, НачалоПериода = "", КонецПериода = "") Экспорт
